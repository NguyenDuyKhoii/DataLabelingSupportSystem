@page
@model DataLabelingSupportSystem.UI.Pages.Admin.ListOfUserModel
@{
    ViewData["Title"] = "User Management";
}

<!-- Flash messages -->
@if (!string.IsNullOrEmpty(Model.UpdateSuccessMessage) || TempData["UpdateSuccessMessage"] != null)
{
    <div class="alert alert-success d-flex align-items-center gap-2 mb-3" role="alert">
        <i class="bi bi-check-circle-fill"></i>
        <div>@(Model.UpdateSuccessMessage ?? TempData["UpdateSuccessMessage"]?.ToString())</div>
    </div>
}

@if (!string.IsNullOrEmpty(Model.DeleteSuccessMessage) || TempData["DeleteSuccessMessage"] != null)
{
    <div class="alert alert-success d-flex align-items-center gap-2 mb-3" role="alert">
        <i class="bi bi-check-circle-fill"></i>
        <div>@(Model.DeleteSuccessMessage ?? TempData["DeleteSuccessMessage"]?.ToString())</div>
    </div>
}

    <!-- Header -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0 text-dark">Administrative Center</h2>
            <p class="text-muted mb-0">Manage platform users and monitor system health in one place.</p>
        </div>
        <div class="text-end">
            <span class="badge rounded-pill px-3 py-2 shadow-sm d-flex align-items-center" style="background: rgba(16, 185, 129, 0.1); color: #059669; border: 1px solid rgba(16, 185, 129, 0.2);">
                <i class="bi bi-shield-check me-2"></i> System Secure
            </span>
        </div>
    </div>

    <!-- Stat Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm overflow-hidden h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="p-3 rounded-circle" style="background: linear-gradient(135deg, rgba(13, 110, 253, 0.15) 0%, rgba(13, 110, 253, 0.05) 100%);">
                            <i class="bi bi-people text-primary fs-4"></i>
                        </div>
                        <span class="badge rounded-pill px-2 py-1" style="background: rgba(13, 110, 253, 0.1); color: #0d6efd; font-size: 11px;">+@Model.Stats.TotalUsers total</span>
                    </div>
                    <h3 class="fw-bold mb-1">@Model.Stats.TotalUsers</h3>
                    <p class="text-muted mb-0 small text-uppercase fw-bold ls-1">Total Users</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm overflow-hidden h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="p-3 rounded-circle" style="background: linear-gradient(135deg, rgba(25, 135, 84, 0.15) 0%, rgba(25, 135, 84, 0.05) 100%);">
                            <i class="bi bi-folder2-open text-success fs-4"></i>
                        </div>
                    </div>
                    <h3 class="fw-bold mb-1">@Model.Stats.TotalProjects</h3>
                    <p class="text-muted mb-0 small text-uppercase fw-bold ls-1">Active Projects</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm overflow-hidden h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="p-3 rounded-circle" style="background: linear-gradient(135deg, rgba(13, 202, 240, 0.15) 0%, rgba(13, 202, 240, 0.05) 100%);">
                            <i class="bi bi-images text-info fs-4"></i>
                        </div>
                    </div>
                    <h3 class="fw-bold mb-1">@Model.Stats.TotalDataItems</h3>
                    <p class="text-muted mb-0 small text-uppercase fw-bold ls-1">Total Assets</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm overflow-hidden h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="p-3 rounded-circle" style="background: linear-gradient(135deg, rgba(255, 193, 7, 0.15) 0%, rgba(255, 193, 7, 0.05) 100%);">
                            <i class="bi bi-pencil-square text-warning fs-4"></i>
                        </div>
                    </div>
                    <h3 class="fw-bold mb-1">@Model.Stats.TotalAnnotations</h3>
                    <p class="text-muted mb-0 small text-uppercase fw-bold ls-1">Total Labels</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Charts Section -->
    <div class="row g-4 mb-4">
        <!-- User Distribution Chart -->
        <div class="col-xl-4 col-lg-5">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                    <h5 class="fw-bold mb-0">Role Distribution</h5>
                    <p class="text-muted small">Access level breakdown</p>
                </div>
                <div class="card-body p-4 d-flex align-items-center">
                    <div style="height: 200px; width: 100%;">
                        <canvas id="userDistChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <!-- Project Status Chart -->
        <div class="col-xl-8 col-lg-7">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-header bg-transparent border-0 pt-4 px-4 pb-0">
                    <h5 class="fw-bold mb-0">System Progress</h5>
                    <p class="text-muted small">Status overview of all projects</p>
                </div>
                <div class="card-body p-4">
                    <div style="height: 200px; width: 100%;">
                        <canvas id="projectStatusChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="dash-card">
        <!-- Header -->
        <div class="dash-card-h d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-3">
                <div class="bg-primary-soft p-2 rounded-3 text-primary">
                    <i class="bi bi-people-fill fs-5"></i>
                </div>
                <div>
                    <h5 class="fw-bold mb-0">User Management <span class="badge bg-primary rounded-pill ms-2" style="font-size: 0.7em;">@Model.Users.Count</span></h5>
                    <p class="text-muted small mb-0">Manage accounts, roles, and status.</p>
                </div>
            </div>
            <button class="btn btn-primary d-flex align-items-center gap-2 px-4 shadow-sm" style="border-radius:12px; font-weight: 600;" data-bs-toggle="modal" data-bs-target="#createUserModal">
                <i class="bi bi-person-plus-fill"></i> Add New User
            </button>
        </div>

    <div class="dash-card-b">
        <!-- Filter -->
        <div class="mb-4 p-4 rounded-4 shadow-sm border-0" style="background: #f8fafc; border: 1px solid #e2e8f0 !important;">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-12 col-md-5">
                    <label class="form-label fw-bold text-dark mb-2" style="font-size:13px; letter-spacing: 0.3px;">SEARCH USER</label>
                    <div class="position-relative">
                        <i class="bi bi-search position-absolute text-muted" style="left:14px; top:50%; transform:translateY(-50%);"></i>
                        <input type="text"
                               class="form-control border-0 shadow-sm"
                               name="Search"
                               value="@Model.Search"
                               placeholder="Search username, name, email..."
                               style="padding-left:40px; border-radius:12px; height: 48px; background: #fff;" />
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label fw-bold text-dark mb-2" style="font-size:13px; letter-spacing: 0.3px;">FILTER BY ROLE</label>
                    <select name="RoleId" class="form-select border-0 shadow-sm" asp-items="Model.RoleList" style="border-radius:12px; height: 48px; background: #fff;">
                        <option value="">-- All Roles --</option>
                    </select>
                </div>

                <div class="col-12 col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100 shadow-sm" style="border-radius:12px; height: 48px; font-weight: 600;">
                        <i class="bi bi-funnel me-1"></i> Apply
                    </button>
                    <a asp-page="./ListOfUser" class="btn btn-outline-secondary w-100 shadow-sm" style="border-radius:12px; height: 48px; font-weight: 600; background: #fff; border-color: #e2e8f0;">
                        <i class="bi bi-arrow-counterclockwise me-1"></i> Reset
                    </a>
                </div>
            </form>
        </div>

        <!-- Table -->
        <div class="dash-card" style="box-shadow:none; border-radius:16px;">
            <div class="dash-card-h d-flex justify-content-between align-items-center">
                <div class="fw-semibold">Users</div>
                <div class="text-muted" style="font-size:12px;">Total: @Model.Users.Count</div>
            </div>

            <div class="dash-card-b p-0">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr class="text-muted" style="font-size:12px;">
                                <th style="width: 70px;">#</th>
                                <th>Username</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th style="width: 140px;">Role</th>
                                <th style="width: 160px;">Created</th>
                                <th style="width: 240px;" class="text-end">Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model.Users.Any())
                            {
                                int stt = 1;
                                @foreach (var user in Model.Users)
                                {
                                    <tr>
                                        <td class="text-muted">@stt</td>
                                        <td class="fw-semibold">@user.Username</td>
                                        <td>@user.Name</td>
                                        <td class="text-muted">@user.Email</td>

                                        <td>
                                            @{
                                                var (roleBadgeClass, roleTextColor) = user.RoleName switch
                                                {
                                                    "Admin" => ("#ffeeee", "#ef233c"),
                                                    "Manager" => ("#fff7ed", "#f97316"),
                                                    "Reviewer" => ("#eef2ff", "#4338ca"),
                                                    "Annotator" => ("#f8fafc", "#64748b"),
                                                    _ => ("#f1f5f9", "#475569")
                                                };
                                            }
                                            <span class="badge rounded-pill fw-bold" style="background: @roleBadgeClass; color: @roleTextColor; padding: 0.5em 1em; border: 1px solid rgba(0,0,0,0.05);">
                                                @user.RoleName
                                            </span>
                                        </td>

                                        <td class="text-muted small">
                                            @user.CreatedAt.ToString("MMM dd, HH:mm")
                                        </td>

                                        <td>
                                            <div class="d-flex justify-content-end gap-2">
                                                <button type="button"
                                                        class="btn btn-icon btn-view"
                                                        title="View details"
                                                        onclick="viewUserDetails('@user.Username', '@user.Name', '@user.Email', '@(user.Phone ?? "")', '@user.RoleName', @user.IsActive.ToString().ToLower(), '@user.CreatedAt.ToString("dd/MM/yyyy HH:mm")')">
                                                    <i class="bi bi-eye"></i>
                                                </button>

                                                <button type="button"
                                                        class="btn btn-icon btn-edit"
                                                        title="Edit user"
                                                        onclick="loadUserForEdit(@user.UserId, '@user.Username', '@user.Name', '@user.Email', '@(user.RoleName)', @user.RoleId, '@(user.Phone ?? "")', @user.IsActive.ToString().ToLower())">
                                                    <i class="bi bi-pencil"></i>
                                                </button>

                                                <form method="post"
                                                      asp-page-handler="Delete"
                                                      asp-route-id="@user.UserId"
                                                      onsubmit="return confirm('Are you sure you want to delete user [@user.Username]? This action will set the status to Inactive.');"
                                                      class="d-inline">
                                                    <button type="submit"
                                                            class="btn btn-icon btn-delete"
                                                            title="Delete user">
                                                        <i class="bi bi-trash"></i>
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                    stt++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-5">
                                        <div class="text-muted">
                                            <i class="bi bi-people" style="font-size:42px; opacity:.55;"></i>
                                            <div class="fw-semibold mt-2">No users found</div>
                                            <div style="font-size:13px;">
                                                Try changing the filters or
                                                <button type="button" class="btn btn-link p-0 align-baseline" data-bs-toggle="modal" data-bs-target="#createUserModal">
                                                    create a new user
                                                </button>.
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>


<!-- ========================================== -->
<!-- MODAL: VIEW USER DETAILS                   -->
<!-- ========================================== -->
<div class="modal fade" id="viewUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius:24px;">
            <div class="modal-body p-0">
                <div class="text-center p-5 mb-0" style="background: linear-gradient(135deg, #f8fafc 0%, #f1f5f9 100%); border-radius: 24px 24px 0 0;">
                    <div class="bg-white shadow-sm rounded-circle d-inline-flex align-items-center justify-content-center mb-3" style="width: 100px; height: 100px; border: 4px solid #fff;">
                        <i class="bi bi-person-fill text-primary" style="font-size:48px;"></i>
                    </div>
                    <h4 id="viewDisplayUsername" class="fw-bold mb-1 text-dark"></h4>
                    <span id="viewDisplayRole" class="badge rounded-pill px-3 py-2" style="background: #eef2ff; color: #4338ca; font-weight: 600;"></span>
                </div>

                <div class="p-4 pt-5">
                    <div class="row g-4">
                        <div class="col-12">
                            <div class="d-flex align-items-center gap-3 p-3 rounded-4 bg-light border-0">
                                <div class="bg-white p-2 rounded-3 shadow-sm text-primary">
                                    <i class="bi bi-person-vcard fs-5"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <label class="small text-muted mb-0 d-block">Full Name</label>
                                    <span id="viewName" class="fw-bold text-dark"></span>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="d-flex align-items-center gap-3 p-3 rounded-4 bg-light border-0">
                                <div class="bg-white p-2 rounded-3 shadow-sm text-primary">
                                    <i class="bi bi-envelope fs-5"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <label class="small text-muted mb-0 d-block">Email Address</label>
                                    <span id="viewEmail" class="fw-bold text-dark"></span>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-center gap-3 p-3 rounded-4 bg-light border-0">
                                <div class="bg-white p-2 rounded-3 shadow-sm text-primary">
                                    <i class="bi bi-telephone fs-5"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <label class="small text-muted mb-0 d-block">Phone</label>
                                    <span id="viewPhone" class="fw-bold text-dark"></span>
                                </div>
                            </div>
                        </div>
                        <div class="col-6">
                            <div class="d-flex align-items-center gap-3 p-3 rounded-4 bg-light border-0">
                                <div class="bg-white p-2 rounded-3 shadow-sm text-primary">
                                    <i class="bi bi-activity fs-5"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <label class="small text-muted mb-0 d-block">Status</label>
                                    <span id="viewStatus" class="fw-bold"></span>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="d-flex align-items-center gap-3 p-3 rounded-4 bg-light border-0">
                                <div class="bg-white p-2 rounded-3 shadow-sm text-primary">
                                    <i class="bi bi-calendar-check fs-5"></i>
                                </div>
                                <div class="flex-grow-1">
                                    <label class="small text-muted mb-0 d-block">Registration Date</label>
                                    <span id="viewCreatedAt" class="fw-bold text-dark"></span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer border-0 p-4">
                <button type="button" class="btn btn-primary w-100 py-2 fw-bold" style="border-radius: 12px;" data-bs-dismiss="modal">
                    Got it
                </button>
            </div>
        </div>
    </div>
</div>


<!-- ========================================== -->
<!-- MODAL: CREATE USER                         -->
<!-- ========================================== -->
<div class="modal fade" id="createUserModal" tabindex="-1" aria-labelledby="createUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" style="border-radius:24px; border: none;">
            <div class="modal-header border-0 p-4">
                <h5 class="modal-title fw-bold text-dark d-flex align-items-center gap-2" id="createUserModalLabel">
                    <div class="bg-primary-soft p-2 rounded-3 text-primary">
                        <i class="bi bi-person-plus-fill fs-5"></i>
                    </div>
                    <span>Add New User</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form method="post" asp-page-handler="Create" id="createUserForm" autocomplete="off">
                <div class="modal-body p-4 pt-0">
                    <div class="alert alert-danger shadow-sm border-0 rounded-3 mb-4 d-none" role="alert">
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-exclamation-triangle-fill mt-1"></i>
                            <div class="error-msg"></div>
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="CreateUserInput.Username" class="form-label small text-muted text-uppercase fw-bold">Username</label>
                            <input asp-for="CreateUserInput.Username"
                                   class="form-control"
                                   placeholder="e.g. johndoe"
                                   required />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CreateUserInput.Password" class="form-label small text-muted text-uppercase fw-bold">Password</label>
                            <input asp-for="CreateUserInput.Password"
                                   type="password"
                                   class="form-control"
                                   placeholder="••••••••"
                                   required />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CreateUserInput.Name" class="form-label small text-muted text-uppercase fw-bold">Full Name</label>
                            <input asp-for="CreateUserInput.Name" class="form-control"
                                   placeholder="e.g. John Doe" required />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CreateUserInput.Email" class="form-label small text-muted text-uppercase fw-bold">Email Address</label>
                            <input asp-for="CreateUserInput.Email" type="email" class="form-control" placeholder="john@example.com" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CreateUserInput.Phone" class="form-label small text-muted text-uppercase fw-bold">Phone Number</label>
                            <input asp-for="CreateUserInput.Phone" type="tel" class="form-control" placeholder="+1..." />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CreateUserInput.RoleId" class="form-label small text-muted text-uppercase fw-bold">Assign Role</label>
                            <select asp-for="CreateUserInput.RoleId" asp-items="Model.RoleList"
                                    class="form-select shadow-sm" required>
                                <option value="">Select Role</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="modal-footer border-0 p-4">
                    <button type="button" class="btn btn-light px-4 py-2" style="border-radius: 12px; font-weight: 600;" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4 py-2" style="border-radius: 12px; font-weight: 600;">
                        Create Account
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>


<!-- ========================================== -->
<!-- MODAL: UPDATE USER                         -->
<!-- ========================================== -->
<div class="modal fade" id="updateUserModal" tabindex="-1" aria-labelledby="updateUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" style="border-radius:24px; border: none;">
            <div class="modal-header border-0 p-4">
                <h5 class="modal-title fw-bold text-dark d-flex align-items-center gap-2" id="updateUserModalLabel">
                    <div class="bg-primary-soft p-2 rounded-3 text-primary">
                        <i class="bi bi-pencil-square fs-5"></i>
                    </div>
                    <span>Update Settings</span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form method="post" asp-page-handler="Update" id="updateUserForm">
                <input type="hidden" asp-for="UpdateUserInput.UserId" id="updateUserId" />
                <div class="modal-body p-4 pt-0">
                    <div class="alert alert-danger shadow-sm border-0 rounded-3 mb-4 d-none" role="alert">
                        <div class="d-flex align-items-start gap-2">
                            <i class="bi bi-exclamation-triangle-fill mt-1"></i>
                            <div class="error-msg"></div>
                        </div>
                    </div>

                    <div class="mb-4 d-flex align-items-center gap-3 p-3 rounded-4" style="background: #f8fafc;">
                        <div class="bg-white p-2 rounded-3 shadow-sm text-primary">
                           <i class="bi bi-person-lock fs-5"></i>
                        </div>
                        <div class="flex-grow-1">
                            <label class="small text-muted mb-0 d-block text-uppercase fw-bold">System Identifier</label>
                            <input type="text" class="fw-bold text-dark border-0 bg-transparent p-0 w-100" id="updateUsername" readonly />
                        </div>
                    </div>

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="UpdateUserInput.Name" class="form-label small text-muted text-uppercase fw-bold">Full Name</label>
                            <input asp-for="UpdateUserInput.Name" class="form-control"
                                   id="updateName" placeholder="Enter name" required />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UpdateUserInput.Email" class="form-label small text-muted text-uppercase fw-bold">Email Address</label>
                            <input asp-for="UpdateUserInput.Email" type="email" class="form-control"
                                   id="updateEmail" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UpdateUserInput.Phone" class="form-label small text-muted text-uppercase fw-bold">Phone Number</label>
                            <input asp-for="UpdateUserInput.Phone" type="tel" class="form-control"
                                   id="updatePhone" />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="UpdateUserInput.RoleId" class="form-label small text-muted text-uppercase fw-bold">Account Role</label>
                            <select asp-for="UpdateUserInput.RoleId" asp-items="Model.RoleList"
                                    class="form-select shadow-sm" id="updateRoleId" required>
                                <option value="">Select Role</option>
                            </select>
                        </div>

                        <div class="col-12 mt-4">
                            <div class="form-check form-switch p-3 px-5 rounded-4 border-0" style="background: #f8fafc;">
                                <input asp-for="UpdateUserInput.IsActive" class="form-check-input ms-0 me-3 mt-1"
                                       type="checkbox" id="updateIsActive" style="width: 2.5rem; height: 1.25rem;" />
                                <label class="form-check-label fw-bold text-dark mt-1" for="updateIsActive">
                                    Account Status: <span class="text-primary">Active</span>
                                </label>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer border-0 p-4">
                    <button type="button" class="btn btn-light px-4 py-2" style="border-radius: 12px; font-weight: 600;" data-bs-dismiss="modal">Close</button>
                    <button type="submit" class="btn btn-primary px-4 py-2" style="border-radius: 12px; font-weight: 600;">
                        Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        .ls-1 { letter-spacing: 0.5px; }
        .bg-primary-soft { background: rgba(67, 97, 238, 0.08); color: #4361ee; }
        
        .card { 
            border-radius: 1.25rem; 
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .card:hover { 
            transform: translateY(-5px); 
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1) !important;
        }

        .btn-icon {
            width: 36px;
            height: 36px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 10px;
            transition: all 0.2s;
            border: 1px solid #e2e8f0;
            background: #fff;
            color: #64748b;
        }
        .btn-view:hover { background: #eff6ff; color: #3b82f6; border-color: #3b82f6; }
        .btn-edit:hover { background: #f0fdf4; color: #22c55e; border-color: #22c55e; }
        .btn-delete:hover { background: #fef2f2; color: #ef4444; border-color: #ef4444; }

        .table thead th {
            text-transform: uppercase;
            letter-spacing: 0.05em;
            font-weight: 700;
            padding: 1rem;
            background: #f8fafc;
            border-bottom: 2px solid #f1f5f9;
        }

        .table tbody tr {
            transition: background 0.2s;
        }
        .table tbody tr:hover {
            background: #f8fafc !important;
        }

        .modal-content {
            border: none;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
        }
        .modal-header {
            border-bottom: 1px solid #f1f5f9;
            background: #fff;
            padding: 1.5rem;
        }
        .modal-footer {
            border-top: 1px solid #f1f5f9;
            padding: 1.25rem;
        }
        .form-label {
            font-weight: 600;
            color: #334155;
            margin-bottom: 0.5rem;
        }
        .form-control, .form-select {
            border-radius: 10px;
            padding: 0.6rem 1rem;
            border: 1px solid #e2e8f0;
            transition: all 0.2s;
        }
        .form-control:focus, .form-select:focus {
            border-color: #3b82f6;
            box-shadow: 0 0 0 4px rgba(59, 130, 246, 0.1);
        }
    </style>
    <script>
        // Charts Initialization
        document.addEventListener('DOMContentLoaded', function () {
            // User Distribution Chart
            const userDistCtx = document.getElementById('userDistChart').getContext('2d');
            new Chart(userDistCtx, {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.Stats.UserDistribution.Select(x => x.RoleName))),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(Model.Stats.UserDistribution.Select(x => x.Count))),
                        backgroundColor: [
                            '#4361ee', // Primary Blue
                            '#3f37c9', // Dark Indigo
                            '#4895ef', // Soft Blue
                            '#4cc9f0', // Cyan
                            '#f72585'  // Pink
                        ],
                        borderWidth: 0,
                        hoverOffset: 15
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    cutout: '70%',
                    plugins: {
                        legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20, font: { size: 11, weight: '600' } } }
                    }
                }
            });

            // Project Status Chart
            const projectStatusCtx = document.getElementById('projectStatusChart').getContext('2d');
            const projectGradients = projectStatusCtx.createLinearGradient(0, 0, 0, 400);
            projectGradients.addColorStop(0, 'rgba(67, 97, 238, 0.8)');
            projectGradients.addColorStop(1, 'rgba(67, 97, 238, 0.1)');

            new Chart(projectStatusCtx, {
                type: 'bar',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.Stats.ProjectDistribution.Select(x => x.Status))),
                    datasets: [{
                        label: 'Projects',
                        data: @Html.Raw(Json.Serialize(Model.Stats.ProjectDistribution.Select(x => x.Count))),
                        backgroundColor: projectGradients,
                        borderRadius: 8,
                        barThickness: 35
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { legend: { display: false } },
                    scales: {
                        y: { beginAtZero: true, grid: { display: true, color: '#f1f5f9' }, border: { display: false } },
                        x: { grid: { display: false }, border: { display: false } }
                    }
                }
            });
        });

        // Global utility functions
        function viewUserDetails(username, name, email, phone, roleName, isActive, createdAt) {
            document.getElementById('viewDisplayUsername').innerText = username;
            document.getElementById('viewDisplayRole').innerText = roleName;
            document.getElementById('viewName').innerText = name || 'N/A';
            document.getElementById('viewEmail').innerText = email || 'N/A';
            document.getElementById('viewPhone').innerText = phone || 'N/A';
            document.getElementById('viewCreatedAt').innerText = createdAt;

            var statusSpan = document.getElementById('viewStatus');
            if (isActive === true || isActive === 'true') {
                statusSpan.innerText = 'Active ✅';
                statusSpan.style.color = '#059669';
            } else {
                statusSpan.innerText = 'Suspended 🔒';
                statusSpan.style.color = '#ef4444';
            }

            var modalElem = document.getElementById('viewUserModal');
            var viewModal = bootstrap.Modal.getOrCreateInstance(modalElem);
            viewModal.show();
        }

        function loadUserForEdit(userId, username, name, email, roleName, roleId, phone, isActive) {
            document.getElementById('updateUserId').value = userId;
            document.getElementById('updateName').value = name || '';
            document.getElementById('updateEmail').value = email || '';
            document.getElementById('updatePhone').value = phone || '';
            document.getElementById('updateRoleId').value = roleId || '';
            document.getElementById('updateIsActive').checked = (isActive === true || isActive === 'true');
            document.getElementById('updateUsername').value = username || '';

            var modalElem = document.getElementById('updateUserModal');
            var updateModal = bootstrap.Modal.getOrCreateInstance(modalElem);
            updateModal.show();
        }

        document.addEventListener('DOMContentLoaded', function () {

            // Reset form + hide alert when modal is closed
            function setupModalReset(modalId, formId) {
                var modalElem = document.getElementById(modalId);
                if (!modalElem) return;

                modalElem.addEventListener('hidden.bs.modal', function () {
                    var form = document.getElementById(formId);
                    if (form) form.reset();

                    // FIX: hide alert using d-none (don't use style.display to avoid bootstrap conflict)
                    var alertDiv = modalElem.querySelector('.alert-danger');
                    if (alertDiv) alertDiv.classList.add('d-none');

                    var errorBox = modalElem.querySelector('.error-msg');
                    if (errorBox) errorBox.innerHTML = '';
                });
            }

            setupModalReset('createUserModal', 'createUserForm');
            setupModalReset('updateUserModal', 'updateUserForm');

            // Handle form submission via Fetch (AJAX)
            function handleFormSubmit(formId, modalId, handlerName) {
                var form = document.getElementById(formId);
                if (!form) return;

                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    e.stopPropagation();

                    var formData = new FormData(form);
                    var url = window.location.pathname + '?handler=' + handlerName;

                    fetch(url, {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        }
                    })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                window.location.reload();
                            } else {
                                var modalElem = document.getElementById(modalId);
                                var alertDiv = modalElem.querySelector('.alert-danger');
                                var errorBox = modalElem.querySelector('.error-msg');

                                var errorText = data.message;
                                if (data.errors && data.errors.length > 0) {
                                    errorText += "<ul class='mb-0 mt-2'>" + data.errors.map(err => "<li>" + err + "</li>").join('') + "</ul>";
                                }

                                if (errorBox) errorBox.innerHTML = errorText;

                                // FIX: show alert using d-none
                                if (alertDiv) alertDiv.classList.remove('d-none');
                            }
                        })
                        .catch(error => {
                            console.error('Error:', error);
                            alert("An error occurred: " + error.message);
                        });
                });
            }

            handleFormSubmit('createUserForm', 'createUserModal', 'Create');
            handleFormSubmit('updateUserForm', 'updateUserModal', 'Update');
        });
    </script>
}
