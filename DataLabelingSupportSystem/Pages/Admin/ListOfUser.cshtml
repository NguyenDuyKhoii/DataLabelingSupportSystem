@page
@model DataLabelingSupportSystem.UI.Pages.Admin.ListOfUserModel
@{
    ViewData["Title"] = "User Management";
}

<!-- Flash messages -->
@if (!string.IsNullOrEmpty(Model.UpdateSuccessMessage) || TempData["UpdateSuccessMessage"] != null)
{
    <div class="alert alert-success d-flex align-items-center gap-2 mb-3" role="alert">
        <i class="bi bi-check-circle-fill"></i>
        <div>@(Model.UpdateSuccessMessage ?? TempData["UpdateSuccessMessage"]?.ToString())</div>
    </div>
}

@if (!string.IsNullOrEmpty(Model.DeleteSuccessMessage) || TempData["DeleteSuccessMessage"] != null)
{
    <div class="alert alert-success d-flex align-items-center gap-2 mb-3" role="alert">
        <i class="bi bi-check-circle-fill"></i>
        <div>@(Model.DeleteSuccessMessage ?? TempData["DeleteSuccessMessage"]?.ToString())</div>
    </div>
}

<div class="dash-card">
    <!-- Header -->
    <div class="dash-card-h d-flex justify-content-between align-items-center">
        <div>
            <div class="fw-semibold d-flex align-items-center gap-2">
                <i class="bi bi-people"></i>
                <span>User Management</span>
                <span class="badge bg-primary">@Model.Users.Count</span>
            </div>
            <div class="text-muted" style="font-size:13px;">
                Manage accounts, roles, and status. Filter users by keyword and role.
            </div>
        </div>

        <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createUserModal">
            <i class="bi bi-plus-circle"></i> Add New User
        </button>
    </div>

    <div class="dash-card-b">
        <!-- Filter -->
        <div class="border rounded-4 p-3 mb-3" style="border-color: var(--dash-border) !important;">
            <form method="get" class="row g-3 align-items-end">
                <div class="col-12 col-md-5">
                    <label class="form-label fw-semibold" style="font-size:13px;">Search</label>
                    <div class="position-relative">
                        <i class="bi bi-search position-absolute" style="left:12px; top:50%; transform:translateY(-50%); color: rgba(15,23,42,.55);"></i>
                        <input type="text"
                               class="form-control"
                               name="Search"
                               value="@Model.Search"
                               placeholder="Username, Name, Email..."
                               style="padding-left:36px; border-radius:14px;" />
                    </div>
                </div>

                <div class="col-12 col-md-4">
                    <label class="form-label fw-semibold" style="font-size:13px;">Role</label>
                    <!-- keep name="RoleId" + asp-items -->
                    <select name="RoleId" class="form-select" asp-items="Model.RoleList" style="border-radius:14px;">
                        <option value="">-- All --</option>
                    </select>
                </div>

                <div class="col-12 col-md-3 d-flex gap-2">
                    <button type="submit" class="btn btn-outline-primary w-100">
                        <i class="bi bi-funnel"></i> Filter
                    </button>
                    <a asp-page="./ListOfUser" class="btn btn-outline-secondary w-100">
                        <i class="bi bi-arrow-counterclockwise"></i> Reset
                    </a>
                </div>
            </form>
        </div>

        <!-- Table -->
        <div class="dash-card" style="box-shadow:none; border-radius:16px;">
            <div class="dash-card-h d-flex justify-content-between align-items-center">
                <div class="fw-semibold">Users</div>
                <div class="text-muted" style="font-size:12px;">Total: @Model.Users.Count</div>
            </div>

            <div class="dash-card-b p-0">
                <div class="table-responsive">
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr class="text-muted" style="font-size:12px;">
                                <th style="width: 70px;">#</th>
                                <th>Username</th>
                                <th>Name</th>
                                <th>Email</th>
                                <th style="width: 140px;">Role</th>
                                <th style="width: 160px;">Created</th>
                                <th style="width: 240px;" class="text-end">Actions</th>
                            </tr>
                        </thead>

                        <tbody>
                            @if (Model.Users.Any())
                            {
                                int stt = 1;
                                @foreach (var user in Model.Users)
                                {
                                    <tr>
                                        <td class="text-muted">@stt</td>
                                        <td class="fw-semibold">@user.Username</td>
                                        <td>@user.Name</td>
                                        <td class="text-muted">@user.Email</td>

                                        <td>
                                            @{
                                                string badgeClass = user.RoleName switch
                                                {
                                                    "Admin" => "bg-danger",
                                                    "Manager" => "bg-warning text-dark",
                                                    "Reviewer" => "bg-info",
                                                    "Annotator" => "bg-secondary",
                                                    _ => "bg-light text-dark"
                                                };
                                            }
                                            <span class="badge @badgeClass">@user.RoleName</span>
                                        </td>

                                        <td class="text-muted">
                                            @user.CreatedAt.ToString("dd/MM HH:mm")
                                        </td>

                                        <td>
                                            <div class="d-flex justify-content-end gap-2">
                                                <!-- VIEW -->
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-secondary d-flex align-items-center gap-1"
                                                        title="View details"
                                                        onclick="viewUserDetails('@user.Username', '@user.Name', '@user.Email', '@(user.Phone ?? "")', '@user.RoleName', @user.IsActive.ToString().ToLower(), '@user.CreatedAt.ToString("dd/MM/yyyy HH:mm")')">
                                                    <i class="bi bi-eye"></i> View
                                                </button>

                                                <!-- EDIT -->
                                                <button type="button"
                                                        class="btn btn-sm btn-outline-primary d-flex align-items-center gap-1"
                                                        title="Edit user"
                                                        onclick="loadUserForEdit(@user.UserId, '@user.Username', '@user.Name', '@user.Email', '@(user.RoleName)', @user.RoleId, '@(user.Phone ?? "")', @user.IsActive.ToString().ToLower())">
                                                    <i class="bi bi-pencil"></i> Edit
                                                </button>

                                                <!-- DELETE -->
                                                <form method="post"
                                                      asp-page-handler="Delete"
                                                      asp-route-id="@user.UserId"
                                                      onsubmit="return confirm('Are you sure you want to delete user [@user.Username]? This action will set the status to Inactive.');"
                                                      class="d-inline">
                                                    <button type="submit"
                                                            class="btn btn-sm btn-outline-danger d-flex align-items-center gap-1"
                                                            title="Delete user">
                                                        <i class="bi bi-trash"></i> Delete
                                                    </button>
                                                </form>
                                            </div>
                                        </td>
                                    </tr>
                                    stt++;
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="7" class="text-center py-5">
                                        <div class="text-muted">
                                            <i class="bi bi-people" style="font-size:42px; opacity:.55;"></i>
                                            <div class="fw-semibold mt-2">No users found</div>
                                            <div style="font-size:13px;">
                                                Try changing the filters or
                                                <button type="button" class="btn btn-link p-0 align-baseline" data-bs-toggle="modal" data-bs-target="#createUserModal">
                                                    create a new user
                                                </button>.
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    </div>
</div>


<!-- ========================================== -->
<!-- MODAL: VIEW USER DETAILS                   -->
<!-- ========================================== -->
<div class="modal fade" id="viewUserModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content" style="border-radius:18px; overflow:hidden;">
            <div class="modal-header">
                <h5 class="modal-title d-flex align-items-center gap-2">
                    <i class="bi bi-person-vcard"></i> Detailed Information
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body">
                <div class="text-center mb-4">
                    <div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 80px; height: 80px;">
                        <i class="bi bi-person" style="font-size:40px; color: rgba(15,23,42,.6);"></i>
                    </div>
                    <h5 id="viewDisplayUsername" class="mb-0"></h5>
                    <span id="viewDisplayRole" class="badge bg-primary"></span>
                </div>

                <div class="row g-3">
                    <div class="col-6">
                        <label class="form-label small text-muted">Full Name</label>
                        <input type="text" class="form-control bg-white" id="viewName" readonly />
                    </div>
                    <div class="col-6">
                        <label class="form-label small text-muted">Phone Number</label>
                        <input type="text" class="form-control bg-white" id="viewPhone" readonly />
                    </div>
                    <div class="col-12">
                        <label class="form-label small text-muted">Email</label>
                        <input type="text" class="form-control bg-white" id="viewEmail" readonly />
                    </div>
                    <div class="col-6">
                        <label class="form-label small text-muted">Status</label>
                        <input type="text" class="form-control bg-white" id="viewStatus" readonly />
                    </div>
                    <div class="col-6">
                        <label class="form-label small text-muted">Created Date</label>
                        <input type="text" class="form-control bg-white" id="viewCreatedAt" readonly />
                    </div>
                </div>
            </div>

            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                    <i class="bi bi-x-lg"></i> Close
                </button>
            </div>
        </div>
    </div>
</div>


<!-- ========================================== -->
<!-- MODAL: CREATE USER                         -->
<!-- ========================================== -->
<div class="modal fade" id="createUserModal" tabindex="-1" aria-labelledby="createUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" style="border-radius:18px; overflow:hidden;">
            <div class="modal-header">
                <h5 class="modal-title d-flex align-items-center gap-2" id="createUserModalLabel">
                    <i class="bi bi-person-plus"></i> Add New User
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form method="post" asp-page-handler="Create" id="createUserForm" autocomplete="off">
                <div class="modal-body">
                    <!-- FIX: use d-none to hide, avoid d-flex override -->
                    <div class="alert alert-danger align-items-start gap-2 d-none" role="alert">
                        <i class="bi bi-exclamation-triangle-fill mt-1"></i>
                        <div class="error-msg"></div>
                        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CreateUserInput.Username" class="form-label">
                                Username <span class="text-danger">*</span>
                            </label>
                            <input asp-for="CreateUserInput.Username"
                                   class="form-control"
                                   placeholder="Enter username"
                                   autocomplete="off"
                                   autocapitalize="off"
                                   autocorrect="off"
                                   required />

                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="CreateUserInput.Password" class="form-label">
                                Password <span class="text-danger">*</span>
                            </label>
                            <input asp-for="CreateUserInput.Password"
                                   type="password"
                                   class="form-control"
                                   placeholder="Minimum 6 characters"
                                   autocomplete="new-password"
                                   required />

                            <div class="form-text">Minimum 6 characters</div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CreateUserInput.Name" class="form-label">
                                Name <span class="text-danger">*</span>
                            </label>
                            <input asp-for="CreateUserInput.Name" class="form-control"
                                   placeholder="Enter full name" required />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="CreateUserInput.Email" class="form-label">Email</label>
                            <input asp-for="CreateUserInput.Email" type="email" class="form-control" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="CreateUserInput.Phone" class="form-label">Phone</label>
                            <input asp-for="CreateUserInput.Phone" type="tel" class="form-control" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="CreateUserInput.RoleId" class="form-label">
                                Role <span class="text-danger">*</span>
                            </label>
                            <select asp-for="CreateUserInput.RoleId" asp-items="Model.RoleList"
                                    class="form-select" required>
                                <option value="">-- Select role --</option>
                            </select>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-lg"></i> Close
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check2-circle"></i> Create User
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>


<!-- ========================================== -->
<!-- MODAL: UPDATE USER                         -->
<!-- ========================================== -->
<div class="modal fade" id="updateUserModal" tabindex="-1" aria-labelledby="updateUserModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content" style="border-radius:18px; overflow:hidden;">
            <div class="modal-header">
                <h5 class="modal-title d-flex align-items-center gap-2" id="updateUserModalLabel">
                    <i class="bi bi-pencil-square"></i> Update User
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form method="post" asp-page-handler="Update" id="updateUserForm">
                <input type="hidden" asp-for="UpdateUserInput.UserId" id="updateUserId" />
                <!-- Anti-autofill: browser will fill these 2 dummy fields instead of real ones -->
                <input type="text" name="fake_username" autocomplete="username" class="d-none" />
                <input type="password" name="fake_password" autocomplete="current-password" class="d-none" />

                <div class="modal-body">
                    <!-- FIX: use d-none to hide, avoid d-flex override -->
                    <div class="alert alert-danger align-items-start gap-2 d-none" role="alert">
                        <i class="bi bi-exclamation-triangle-fill mt-1"></i>
                        <div class="error-msg"></div>
                        <button type="button" class="btn-close ms-auto" data-bs-dismiss="alert"></button>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Username</label>
                        <input type="text" class="form-control" id="updateUsername" readonly disabled />
                        <div class="form-text">Username cannot be changed</div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="UpdateUserInput.Name" class="form-label">
                                Name <span class="text-danger">*</span>
                            </label>
                            <input asp-for="UpdateUserInput.Name" class="form-control"
                                   id="updateName" placeholder="Enter full name" required />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="UpdateUserInput.Email" class="form-label">Email</label>
                            <input asp-for="UpdateUserInput.Email" type="email" class="form-control"
                                   id="updateEmail" />
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="UpdateUserInput.Phone" class="form-label">Phone</label>
                            <input asp-for="UpdateUserInput.Phone" type="tel" class="form-control"
                                   id="updatePhone" />
                        </div>

                        <div class="col-md-6 mb-3">
                            <label asp-for="UpdateUserInput.RoleId" class="form-label">
                                Role <span class="text-danger">*</span>
                            </label>
                            <select asp-for="UpdateUserInput.RoleId" asp-items="Model.RoleList"
                                    class="form-select" id="updateRoleId" required>
                                <option value="">-- Select role --</option>
                            </select>
                        </div>
                    </div>

                    <div class="mb-3">
                        <div class="form-check form-switch">
                            <input asp-for="UpdateUserInput.IsActive" class="form-check-input"
                                   type="checkbox" id="updateIsActive" />
                            <label class="form-check-label" for="updateIsActive">
                                Activate Account
                            </label>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
                        <i class="bi bi-x-lg"></i> Close
                    </button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save2"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Global utility functions
        function viewUserDetails(username, name, email, phone, roleName, isActive, createdAt) {
            document.getElementById('viewDisplayUsername').innerText = username;
            document.getElementById('viewDisplayRole').innerText = roleName;
            document.getElementById('viewName').value = name || 'Not updated';
            document.getElementById('viewEmail').value = email || 'Not updated';
            document.getElementById('viewPhone').value = phone || 'Not updated';
            document.getElementById('viewCreatedAt').value = createdAt;

            var statusInput = document.getElementById('viewStatus');
            if (isActive === true || isActive === 'true') {
                statusInput.value = 'Active';
                statusInput.classList.remove('text-danger');
                statusInput.classList.add('text-success', 'fw-bold');
            } else {
                statusInput.value = 'Locked / Inactive';
                statusInput.classList.remove('text-success');
                statusInput.classList.add('text-danger', 'fw-bold');
            }

            var modalElem = document.getElementById('viewUserModal');
            var viewModal = bootstrap.Modal.getOrCreateInstance(modalElem);
            viewModal.show();
        }

        function loadUserForEdit(userId, username, name, email, roleName, roleId, phone, isActive) {
            document.getElementById('updateUserId').value = userId;
            document.getElementById('updateName').value = name || '';
            document.getElementById('updateEmail').value = email || '';
            document.getElementById('updatePhone').value = phone || '';
            document.getElementById('updateRoleId').value = roleId || '';
            document.getElementById('updateIsActive').checked = (isActive === true || isActive === 'true');
            document.getElementById('updateUsername').value = username || '';

            var modalElem = document.getElementById('updateUserModal');
            var updateModal = bootstrap.Modal.getOrCreateInstance(modalElem);
            updateModal.show();
        }

        document.addEventListener('DOMContentLoaded', function () {

            // Reset form + hide alert when modal is closed
            function setupModalReset(modalId, formId) {
                var modalElem = document.getElementById(modalId);
                if (!modalElem) return;

                modalElem.addEventListener('hidden.bs.modal', function () {
                    var form = document.getElementById(formId);
                    if (form) form.reset();

                    // FIX: hide alert using d-none (don't use style.display to avoid bootstrap conflict)
                    var alertDiv = modalElem.querySelector('.alert-danger');
                    if (alertDiv) alertDiv.classList.add('d-none');

                    var errorBox = modalElem.querySelector('.error-msg');
                    if (errorBox) errorBox.innerHTML = '';
                });
            }

            setupModalReset('createUserModal', 'createUserForm');
            setupModalReset('updateUserModal', 'updateUserForm');

            // Handle form submission via Fetch (AJAX)
            function handleFormSubmit(formId, modalId, handlerName) {
                var form = document.getElementById(formId);
                if (!form) return;

                form.addEventListener('submit', function (e) {
                    e.preventDefault();
                    e.stopPropagation();

                    var formData = new FormData(form);
                    var url = window.location.pathname + '?handler=' + handlerName;

                    fetch(url, {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        }
                    })
                        .then(response => response.json())
                        .then(data => {
                            if (data.success) {
                                window.location.reload();
                            } else {
                                var modalElem = document.getElementById(modalId);
                                var alertDiv = modalElem.querySelector('.alert-danger');
                                var errorBox = modalElem.querySelector('.error-msg');

                                var errorText = data.message;
                                if (data.errors && data.errors.length > 0) {
                                    errorText += "<ul class='mb-0 mt-2'>" + data.errors.map(err => "<li>" + err + "</li>").join('') + "</ul>";
                                }

                                if (errorBox) errorBox.innerHTML = errorText;

                                // FIX: show alert using d-none
                                if (alertDiv) alertDiv.classList.remove('d-none');
                            }
                        })
                        .catch(error => {
                            console.error('Error:', error);
                            alert("An error occurred: " + error.message);
                        });
                });
            }

            handleFormSubmit('createUserForm', 'createUserModal', 'Create');
            handleFormSubmit('updateUserForm', 'updateUserModal', 'Update');
        });
    </script>
}
