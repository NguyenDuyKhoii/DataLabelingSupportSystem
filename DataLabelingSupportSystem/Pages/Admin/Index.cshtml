@page
@model DataLabelingSupportSystem.UI.Pages.Admin.IndexModel
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container-fluid py-4">
    <!-- Header Summary -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold mb-0">System Overview</h2>
            <p class="text-muted mb-0">Monitor platform usage and system health.</p>
        </div>
        <div class="text-end">
            <span class="badge rounded-pill px-3 py-2 shadow-sm" style="background: rgba(16, 185, 129, 0.1); color: #059669; border: 1px solid rgba(16, 185, 129, 0.2);">
                <i class="bi bi-shield-check me-1"></i> System Secure
            </span>
        </div>
    </div>

    <!-- Stat Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="card border-0 shadow-sm overflow-hidden h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="p-3 rounded-circle" style="background: linear-gradient(135deg, rgba(13, 110, 253, 0.15) 0%, rgba(13, 110, 253, 0.05) 100%);">
                            <i class="bi bi-people text-primary fs-4"></i>
                        </div>
                        <span class="badge rounded-pill px-2 py-1" style="background: rgba(13, 110, 253, 0.1); color: #0d6efd; font-size: 11px;">+@Model.Stats.TotalUsers new</span>
                    </div>
                    <h3 class="fw-bold mb-1">@Model.Stats.TotalUsers</h3>
                    <p class="text-muted mb-0 small text-uppercase fw-bold ls-1">Total Users</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm overflow-hidden h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="p-3 rounded-circle" style="background: linear-gradient(135deg, rgba(25, 135, 84, 0.15) 0%, rgba(25, 135, 84, 0.05) 100%);">
                            <i class="bi bi-folder2-open text-success fs-4"></i>
                        </div>
                    </div>
                    <h3 class="fw-bold mb-1">@Model.Stats.TotalProjects</h3>
                    <p class="text-muted mb-0 small text-uppercase fw-bold ls-1">Total Projects</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm overflow-hidden h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="p-3 rounded-circle" style="background: linear-gradient(135deg, rgba(13, 202, 240, 0.15) 0%, rgba(13, 202, 240, 0.05) 100%);">
                            <i class="bi bi-images text-info fs-4"></i>
                        </div>
                    </div>
                    <h3 class="fw-bold mb-1">@Model.Stats.TotalDataItems</h3>
                    <p class="text-muted mb-0 small text-uppercase fw-bold ls-1">Total Assets</p>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-0 shadow-sm overflow-hidden h-100">
                <div class="card-body p-4">
                    <div class="d-flex align-items-center justify-content-between mb-3">
                        <div class="p-3 rounded-circle" style="background: linear-gradient(135deg, rgba(255, 193, 7, 0.15) 0%, rgba(255, 193, 7, 0.05) 100%);">
                            <i class="bi bi-pencil-square text-warning fs-4"></i>
                        </div>
                    </div>
                    <h3 class="fw-bold mb-1">@Model.Stats.TotalAnnotations</h3>
                    <p class="text-muted mb-0 small text-uppercase fw-bold ls-1">Total Labels</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Style improvements directly in file for quick iteration -->
    <style>
        :root {
            --admin-primary: #4361ee;
            --admin-success: #2ec4b6;
            --admin-info: #3f37c9;
            --admin-warning: #ff9f1c;
            --admin-card-bg: #fff;
        }

        .ls-1 { letter-spacing: 0.5px; }
        
        .card { 
            border-radius: 1.25rem; 
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            background: var(--admin-card-bg);
        }
        
        .card:hover { 
            transform: translateY(-5px); 
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1) !important;
        }

        .timeline-item {
            position: relative;
            padding-left: 1.5rem;
        }

        .timeline-line {
            position: absolute;
            left: 19px;
            top: 40px;
            bottom: -20px;
            width: 2px;
            background: #f1f5f9;
        }

        .bg-primary-soft { background: rgba(67, 97, 238, 0.08); color: #4361ee; }
        .bg-success-soft { background: rgba(46, 196, 182, 0.08); color: #2ec4b6; }
        .bg-info-soft { background: rgba(63, 55, 201, 0.08); color: #3f37c9; }
        .bg-warning-soft { background: rgba(255, 159, 28, 0.08); color: #ff9f1c; }
        .bg-danger-soft { background: rgba(239, 35, 60, 0.08); color: #ef233c; }

        .btn-link-custom {
            color: var(--admin-primary);
            font-weight: 600;
            font-size: 0.85rem;
            text-decoration: none;
            transition: all 0.2s;
        }
        .btn-link-custom:hover { opacity: 0.8; }

        .list-group-item-custom {
            border: none;
            margin-bottom: 0.75rem;
            border-radius: 0.75rem !important;
            transition: all 0.2s;
            background: transparent;
        }
        .list-group-item-custom:hover {
            background: #f8fafc;
            transform: translateX(5px);
        }
    </style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            // User Distribution Chart
            const userCtx = document.getElementById('userDistChart').getContext('2d');
            new Chart(userCtx, {
                type: 'doughnut',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.Stats.UserDistribution.Select(d => d.RoleName))),
                    datasets: [{
                        data: @Html.Raw(Json.Serialize(Model.Stats.UserDistribution.Select(d => d.Count))),
                        backgroundColor: ['#0d6efd', '#198754', '#ffc107', '#0dcaf0', '#6c757d'],
                        hoverOffset: 15,
                        borderWidth: 0
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    cutout: '75%',
                    plugins: {
                        legend: { position: 'bottom', labels: { usePointStyle: true, padding: 20 } }
                    }
                }
            });

            // Project Status Chart
            const projCtx = document.getElementById('projectStatusChart').getContext('2d');
            new Chart(projCtx, {
                type: 'bar',
                data: {
                    labels: @Html.Raw(Json.Serialize(Model.Stats.ProjectDistribution.Select(d => d.Status))),
                    datasets: [{
                        label: 'Projects',
                        data: @Html.Raw(Json.Serialize(Model.Stats.ProjectDistribution.Select(d => d.Count))),
                        backgroundColor: '#0d6efd',
                        borderRadius: 8,
                        barThickness: 40
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    scales: {
                        y: { beginAtZero: true, grid: { display: false } },
                        x: { grid: { display: false } }
                    },
                    plugins: {
                        legend: { display: false }
                    }
                }
            });
        });
    </script>
}
