@page
@model DataLabelingSupportSystem.UI.Pages.Annotator.IndexModel
@{
    ViewData["Title"] = "Annotator Dashboard";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2><i class="bi bi-speedometer2"></i> Annotator Dashboard</h2>
        <span class="text-muted">Welcome, @User.Identity?.Name</span>
    </div>

    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-list-task"></i> My Assigned Tasks (@Model.AssignedTasks.Count)</h5>
        </div>
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th># Task ID</th>
                            <th>Project</th>
                            <th>Images to Label</th>
                            <th>Status</th>
                            <th>Action</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.AssignedTasks.Any())
                        {
                            @foreach (var task in Model.AssignedTasks)
                            {
                                <tr>
                                    <td><strong>#@task.TaskId</strong></td>
                                    <td>@task.ProjectName</td>
                                    <td>
                                        <span class="badge bg-info text-dark">@task.ImageCount Images</span>
                                    </td>
                                    <td>
                                        @{
                                            string badgeClass = task.Status.ToString() switch
                                            {
                                                "Assigned" => "bg-secondary",
                                                "InProgress" => "bg-primary",
                                                "Completed" => "bg-success",
                                                _ => "bg-light text-dark"
                                            };
                                        }
                                        <span class="badge @badgeClass">@task.Status</span>
                                    </td>
                                    <td>
                                        <a asp-page="/Annotator/TaskDetails" asp-route-id="@task.TaskId" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-eye"></i> View Images
                                        </a>
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="5" class="text-center text-muted py-4">
                                    You don't have any assigned tasks yet.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
