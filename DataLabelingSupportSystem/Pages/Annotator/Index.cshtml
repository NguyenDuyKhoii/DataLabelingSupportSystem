@page
@model DataLabelingSupportSystem.UI.Pages.Annotator.IndexModel
@{
    ViewData["Title"] = "Annotator Dashboard";
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <div>
        <h3 class="mb-0"><i class="bi bi-speedometer2 me-2"></i>Annotator Dashboard</h3>
        <small class="text-muted">Manage your assigned labeling tasks</small>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0 fw-bold"><i class="bi bi-list-task me-2 text-primary"></i>My Assigned Tasks (@Model.AssignedTasks.Count)</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0" style="font-size: 0.9rem;">
                <thead class="table-light">
                    <tr>
                        <th># Task ID</th>
                        <th>Project</th>
                        <th>Images</th>
                        <th>Status</th>
                        <th class="text-end">Action</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.AssignedTasks.Any())
                    {
                        @foreach (var task in Model.AssignedTasks)
                        {
                            <tr>
                                <td class="fw-bold">#@task.TaskId</td>
                                <td>@task.ProjectName</td>
                                <td>
                                    <span class="badge bg-info bg-opacity-10 text-info border border-info border-opacity-25">@task.ImageCount Images</span>
                                </td>
                                <td>
                                    @{
                                        string badgeClass = task.Status.ToString() switch
                                        {
                                            "Assigned" => "bg-secondary",
                                            "InProgress" => "bg-primary",
                                            "Completed" => "bg-success",
                                            _ => "bg-light text-dark border"
                                        };
                                    }
                                    <span class="badge rounded-pill @badgeClass">@task.Status</span>
                                </td>
                                <td class="text-end">
                                    <a asp-page="/Annotator/TaskDetails" asp-route-id="@task.TaskId" class="btn btn-sm btn-outline-primary shadow-sm">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center text-muted py-5">
                                <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                You don't have any assigned tasks yet.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
