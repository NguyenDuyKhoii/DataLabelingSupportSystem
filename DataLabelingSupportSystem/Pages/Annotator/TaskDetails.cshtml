@page "{id:int}"
@model DataLabelingSupportSystem.UI.Pages.Annotator.TaskDetailsModel
@{
    ViewData["Title"] = "Task Details #" + Model.TaskDetail.TaskId;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <div>
            <h2 class="text-primary mb-0">Project: @Model.TaskDetail.ProjectName</h2>
            <p class="text-muted mb-0">Task ID: #@Model.TaskDetail.TaskId</p>
        </div>
        <div>
            @{
                string badgeClass = Model.TaskDetail.Status.ToString() switch
                {
                    "Assigned" => "bg-secondary",
                    "InProgress" => "bg-primary",
                    "Completed" => "bg-success",
                    _ => "bg-light text-dark"
                };
            }
            <span class="badge @badgeClass fs-6">Status: @Model.TaskDetail.Status</span>
        </div>
    </div>

    <a asp-page="/Annotator/Index" class="btn btn-outline-secondary btn-sm mb-4">&larr; Back to Dashboard</a>

    <div class="card shadow-sm">
        <div class="card-header bg-white d-flex justify-content-between align-items-center">
            <h5 class="mb-0"><i class="bi bi-images"></i> Assigned Images (@Model.TaskDetail.Items.Count)</h5>
        </div>
        <div class="card-body p-4 bg-light">
            <div class="row g-4">
                @if (Model.TaskDetail.Items != null && Model.TaskDetail.Items.Count > 0)
                {
                    @foreach (var item in Model.TaskDetail.Items)
                    {
                        <div class="col-6 col-md-4 col-lg-3">
                            <div class="card h-100 shadow-sm hover-shadow border-0">
                                <a href="@item.ImagePath" target="_blank">
                                    <img src="@item.ImagePath" class="card-img-top rounded-top" style="height: 180px; object-fit: cover;" alt="Assigned Data Item">
                                </a>
                                <div class="card-body p-3 text-center d-flex flex-column justify-content-between">
                                    <small class="text-muted mb-2">Item ID: @item.DataItemId</small>
                                    <button class="btn btn-sm btn-outline-primary w-100 mt-auto">
                                        <i class="bi bi-pencil-square"></i> Annotate Now
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <div class="col-12">
                        <div class="alert alert-secondary text-center py-5 mb-0">
                            <h3 class="text-muted display-6"><i class="bi bi-folder-x"></i></h3>
                            <p class="text-muted mb-0">No images found for this task.</p>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
