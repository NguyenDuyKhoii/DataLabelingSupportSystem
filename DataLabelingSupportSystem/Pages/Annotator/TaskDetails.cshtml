@page "{id:int}"
@model DataLabelingSupportSystem.UI.Pages.Annotator.TaskDetailsModel
@{
    ViewData["Title"] = "Task Details #" + Model.TaskDetail.TaskId;
}

<div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
    <div>
        <h3 class="mb-0"><i class="bi bi-folder2-open me-2"></i>Project: @Model.TaskDetail?.ProjectName</h3>
        <small class="text-muted">Task ID: #@Model.TaskDetail?.TaskId</small>
    </div>

    <div class="d-flex gap-2">
        <a asp-page="/Annotator/Index" class="btn btn-outline-secondary btn-sm shadow-sm">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>
        @{
            string taskBadgeClass = Model.TaskDetail?.Status.ToString() switch
            {
                "Assigned" => "bg-secondary",
                "InProgress" => "bg-primary",
                "Completed" => "bg-success",
                _ => "bg-light text-dark border"
            };
        }
        <span class="badge @taskBadgeClass d-flex align-items-center px-3">Status: @Model.TaskDetail?.Status</span>
    </div>
</div>

<div class="card shadow-sm">
    <div class="card-header bg-white py-3">
        <h5 class="mb-0 fw-bold">Assigned Images (@Model.TaskDetail?.Items.Count)</h5>
    </div>
    <div class="card-body">
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
            @if (Model.TaskDetail?.Items.Any() == true)
            {
                @foreach (var item in Model.TaskDetail.Items)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm border-0 bg-light">
                            <div class="position-relative">
                                <a asp-page="/Annotator/Annotate" asp-route-taskItemId="@item.TaskItemId">
                                    <img src="@item.ImagePath" class="card-img-top rounded-top" style="height: 180px; object-fit: cover;" alt="Assigned Data Item">
                                </a>
                            </div>
                            <div class="card-body p-3 text-center d-flex flex-column justify-content-between bg-white rounded-bottom">
                                <div class="mb-2">
                                    <small class="text-muted d-block mb-1">Item ID: @item.DataItemId</small>
                                    @if (item.LatestStatus != null)
                                    {
                                        string subBadgeClass = item.LatestStatus.ToString() switch
                                        {
                                            "Approved" => "bg-success",
                                            "Rejected" => "bg-danger",
                                            "InReview" => "bg-info text-dark",
                                            "Submitted" => "bg-warning text-dark",
                                            _ => "bg-secondary"
                                        };
                                        <span class="badge @subBadgeClass mb-1">@item.LatestStatus</span>

                                        @if (!string.IsNullOrEmpty(item.ReviewComment))
                                        {
                                            <div class="alert alert-danger px-2 py-1 mb-1 border-0" style="font-size: 0.75rem; background-color: #fff5f5;">
                                                <i class="bi bi-chat-left-text-fill text-danger me-1"></i> @item.ReviewComment
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-dark border mb-1">New</span>
                                    }
                                </div>

                                @{
                                    bool isApproved = item.LatestStatus?.ToString() == "Approved";
                                    string btnClass = isApproved ? "btn-secondary" : "btn-primary";
                                    string tooltip = isApproved ? "Item has been approved and cannot be edited." : "Draw bounding boxes";
                                }
                                <a asp-page="/Annotator/Annotate"
                                   asp-route-taskItemId="@item.TaskItemId"
                                   class="btn @btnClass btn-sm w-100 mt-auto d-flex align-items-center justify-content-center gap-2 @(isApproved ? "disabled" : "")"
                                   title="@tooltip">
                                    <i class="bi bi-bounding-box"></i>
                                    <span>Annotate</span>
                                </a>
                            </div>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="col-12 text-center py-5">
                    <i class="bi bi-image fs-1 text-muted d-block mb-2"></i>
                    <p class="text-muted">No images found for this task.</p>
                </div>
            }
        </div>
    </div>
</div>
