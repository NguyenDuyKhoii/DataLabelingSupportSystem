@{
    var role = (string)(Model?.Role ?? "Manager");
    var currentPath = (Context?.Request?.Path.Value ?? "").ToLowerInvariant();

    // Menu data (reusable)
    var items = role switch
    {
        "Admin" => new[]
        {
            new { Text = "Dashboard", Icon = "bi-speedometer2", Page = "/Admin/Index" },
            new { Text = "Users",      Icon = "bi-people",       Page = "/Admin/ListOfUser" },
        },
        "Reviewer" => new[]
        {
            new { Text = "Review Queue", Icon = "bi-clipboard-check", Page = "/Reviewer/Index" },
        },
        "Annotator" => new[]
        {
            new { Text = "My Tasks", Icon = "bi-table", Page = "/Annotator/Index" },
        },
        _ => new[]
        {
            new { Text = "Dashboard",     Icon = "bi-grid",        Page = "/Manager/Index" },
            new { Text = "Create Project",Icon = "bi-plus-circle", Page = "/Manager/CreateProject" },
        }
    };

    bool IsActive(string page)
    {
        var p = (page ?? "").ToLowerInvariant();
        return currentPath == p || currentPath.StartsWith(p + "/");
    }
}

<aside class="dash-sidebar">
    <div class="dash-brand">
        <div class="dash-brand-badge">DL</div>
        <div>
            <div class="dash-brand-title">Dashboard</div>
            <div class="dash-brand-sub">@role Panel</div>
        </div>
    </div>

    <div class="dash-nav">
        <div class="dash-nav-title">Menu</div>

        @foreach (var it in items)
        {
            <a class="dash-link @(IsActive(it.Page) ? "active" : "")" asp-page="@it.Page">
                <i class="bi @it.Icon"></i>
                <span>@it.Text</span>
            </a>
        }
    </div>
    <!-- Account -->
    <div class="dash-nav mt-3">
        <div class="dash-nav-title">Account</div>

        <form method="post" asp-area="Identity" asp-page="/Account/Logout">
            <button type="submit" class="dash-link w-100 text-start"
                    style="border:0; background:transparent;">
                <i class="bi bi-box-arrow-right"></i>
                <span>Logout</span>
            </button>
        </form>
    </div>

    <div class="mt-auto pt-3" style="opacity:.8; font-size:12px;">
        <div class="px-2">© DataLabelingSupportSystem</div>
    </div>
</aside>
