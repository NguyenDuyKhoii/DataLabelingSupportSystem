@using System.Security.Claims
@{
    var role = (string)(ViewData["DashboardRole"] ?? "Manager");
    var displayName = User.Identity?.Name ?? "User";
    var initial = !string.IsNullOrWhiteSpace(displayName) ? displayName.Trim()[0].ToString().ToUpper() : "U";
}


<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DataLabelingSupportSystem</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/dashboard.css" asp-append-version="true" />
</head>
<body class="dash-body">
    <div class="dash-shell">

        <!-- Mobile overlay -->
        <div class="dash-overlay"></div>

        <!-- Sidebar -->
        @await Html.PartialAsync("_DashboardSidebar", new { Role = role })

        <!-- Main -->
        <div class="dash-main">
            <!-- Topbar -->
            <div class="dash-topbar">
                <div class="dash-topbar-inner d-flex align-items-center w-100">

                    <button class="btn btn-outline-secondary d-lg-none" data-dash-toggle type="button">
                        <i class="bi bi-list"></i>
                    </button>

                    <div class="dash-search">
                        <div class="dash-search-wrap">
                            <i class="bi bi-search"></i>
                            <input class="form-control" placeholder="Search..." />
                        </div>
                    </div>

                    <div class="dash-user dropdown ms-auto">

                        <a class="d-flex align-items-center gap-2 text-decoration-none" href="#" role="button"
                           data-bs-toggle="dropdown" aria-expanded="false">
                            <div class="dash-avatar">@initial</div>
                            <div class="d-none d-sm-block">
                                <div class="dash-user-name">@displayName</div>
                                <div class="dash-user-role">@role</div>
                            </div>
                            <i class="bi bi-chevron-down d-none d-sm-inline" style="color: rgba(15,23,42,.55);"></i>
                        </a>

                        <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                            <li class="px-3 py-2">
                                <div class="fw-semibold">@displayName</div>
                                <div class="text-muted" style="font-size:12px;">@role</div>
                            </li>
                            <li><hr class="dropdown-divider" /></li>

                            <li>
                                <form method="post" asp-area="Identity" asp-page="/Account/Logout" class="px-2">
                                    <button type="submit" class="dropdown-item text-danger">
                                        <i class="bi bi-box-arrow-right me-2"></i> Logout
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>

                </div>
            </div>

            <!-- Content -->
            <main class="dash-content">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="~/js/dashboard.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
