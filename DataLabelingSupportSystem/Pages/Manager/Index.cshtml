@page
@model DataLabelingSupportSystem.UI.Pages.Manager.IndexModel
@{
    ViewData["Title"] = "Quản lý dự án";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>Danh sách dự án của tôi</h2>
        <a asp-page="/Manager/CreateProject" class="btn btn-success">
            + Tạo dự án mới
        </a>
    </div>

    @if (Model.Projects.Count == 0)
    {
        <div class="alert alert-info">
            Bạn chưa có dự án nào. Hãy tạo dự án đầu tiên nhé!
        </div>
    }
    else
    {
        <table class="table table-bordered table-hover">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Tên dự án</th>
                    <th>Trạng thái</th> 
                    <th>Ngày tạo</th>
                    <th>Mô tả</th>
                    <th>Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Projects)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td class="fw-bold">@item.Name</td>
                        
                        <td>
                            @* Tô màu trạng thái cho đẹp *@
                            @if(item.Status == "New") { <span class="badge bg-primary">Mới tạo</span> }
                            else if(item.Status == "InProgress") { <span class="badge bg-warning text-dark">Đang chạy</span> }
                            else { <span class="badge bg-success">Hoàn thành</span> }
                        </td>
                        <td>@item.CreatedDate.ToString("dd/MM/yyyy")</td>
                        <td>@item.Description</td>
                        <td>
                            <a href="#" class="btn btn-sm btn-primary">Xem chi tiết</a>
                            <a href="#" class="btn btn-sm btn-warning">Sửa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>