@page
@model DataLabelingSupportSystem.UI.Pages.Manager.IndexModel
@{
    ViewData["Title"] = "Project Management";
}

<div class="row g-4 mb-4">
    <div class="col-12 col-md-6 col-xl-3">
        <div class="stat-card stat-card-blue">
            <div class="stat-icon"><i class="bi bi-folder-fill"></i></div>
            <div class="stat-title">My Projects</div>
            <div class="stat-value">@Model.Projects.Count</div>
            <div class="stat-meta">Total owned projects</div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="stat-card stat-card-yellow">
            <div class="stat-icon"><i class="bi bi-star-fill"></i></div>
            <div class="stat-title">New</div>
            <div class="stat-value">@Model.Projects.Count(p => p.Status == "New")</div>
            <div class="stat-meta">Waiting to start</div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="stat-card stat-card-indigo">
            <div class="stat-icon"><i class="bi bi-clock-history"></i></div>
            <div class="stat-title">In Progress</div>
            <div class="stat-value">@Model.Projects.Count(p => p.Status == "InProgress")</div>
            <div class="stat-meta">Running tasks</div>
        </div>
    </div>

    <div class="col-12 col-md-6 col-xl-3">
        <div class="stat-card stat-card-green">
            <div class="stat-icon"><i class="bi bi-check-circle-fill"></i></div>
            <div class="stat-title">Completed</div>
            <div class="stat-value">@Model.Projects.Count(p => p.Status != "New" && p.Status != "InProgress")</div>
            <div class="stat-meta">Done</div>
        </div>
    </div>
</div>

<div class="dash-card">
    <div class="dash-card-h d-flex justify-content-between align-items-center">
        <div class="fs-5 fw-bold" style="color: #0b3b6d;">My Projects</div>
        <a asp-page="/Manager/CreateProject" class="btn btn-primary d-flex align-items-center gap-2 px-3" style="border-radius: 10px;">
            <i class="bi bi-plus-lg fs-5"></i> <span>Create New Project</span>
        </a>
    </div>

    <div class="dash-card-b">
        @if (Model.Projects.Count == 0)
        {
            <div class="alert alert-info mb-0">
                You don't have any projects yet. Create your first project now!
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle mb-0">
                    <thead>
                        <tr>
                            <th style="width:80px;">ID</th>
                            <th>Project Name</th>
                            <th style="width:160px;">Status</th>
                            <th style="width:160px;">Created</th>
                            <th>Description</th>
                            <th style="width:220px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Projects)
                        {
                            <tr>
                                <td>@item.Id</td>
                                <td class="fw-semibold">@item.Name</td>

                                <td>
                                    @if (item.Status == "New")
                                    {
                                        <span class="badge badge-soft-primary">New</span>
                                    }
                                    else if (item.Status == "InProgress")
                                    {
                                        <span class="badge badge-soft-warning">In Progress</span>
                                    }
                                    else
                                    {
                                        <span class="badge badge-soft-success">Completed</span>
                                    }
                                </td>

                                <td>@item.CreatedDate.ToString("dd/MM/yyyy")</td>
                                <td class="text-muted">@item.Description</td>

                                <td>
                                    <div class="d-flex gap-2">
                                        <a asp-page="/Manager/Details" asp-route-id="@item.Id" class="btn btn-action btn-outline-secondary">
                                            <i class="bi bi-gear-fill"></i> Manage
                                        </a>
                                        <a asp-page="/Manager/EditProject" asp-route-id="@item.Id" class="btn btn-action btn-outline-primary">
                                            <i class="bi bi-pencil-square"></i> Edit
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>
