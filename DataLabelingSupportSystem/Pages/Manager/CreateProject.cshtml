@page
@model DataLabelingSupportSystem.UI.Pages.Manager.CreateProjectModel
@{
    ViewData["Title"] = "Create Project";
}

<!-- Header (dash-card like /Manager, no stat cards) -->
<div class="dash-card mb-3">
    <div class="dash-card-h d-flex justify-content-between align-items-center">
        <div>
            <div class="fw-semibold" style="font-size:18px;">Create New Project</div>
            <div class="text-muted" style="font-size:13px;">Create a project to manage labels and dataset images.</div>
        </div>

        <div class="d-flex gap-2">
            <a asp-page="/Manager/Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>
</div>

<!-- Form card -->
<div class="dash-card" style="max-width: 980px;">
    <div class="dash-card-h d-flex justify-content-between align-items-center">
        <div class="fw-semibold">Project Information</div>
        <small class="text-muted">Fill in name and description</small>
    </div>

    <div class="dash-card-b">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Input.Name" class="form-label fw-semibold">Project Name</label>
                    <input asp-for="Input.Name" class="form-control" placeholder="e.g. Brain MRI Labeling" />
                    <span asp-validation-for="Input.Name" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Input.Description" class="form-label fw-semibold">Description</label>
                    <textarea asp-for="Input.Description" class="form-control" rows="6"
                              placeholder="Describe your project goal, dataset, notes..."></textarea>
                    <span asp-validation-for="Input.Description" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <div class="d-flex justify-content-end gap-2 pt-3" style="border-top:1px solid var(--dash-border);">
                        <a asp-page="/Manager/Index" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-check2-circle"></i> Create
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
