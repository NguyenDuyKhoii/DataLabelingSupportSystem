@page
@model DataLabelingSupportSystem.UI.Pages.Manager.CreateProjectModel
@{
    ViewData["Title"] = "Create New Project";
}

<div class="container mt-4">
    <h2>Create New Project</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <form method="post">
                @* Display general validation errors if any *@
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="form-group mb-3">
                    <label asp-for="Input.Name" class="control-label font-weight-bold">Project Name</label>
                    <input asp-for="Input.Name" class="form-control" placeholder="Enter project name..." />
                    <span asp-validation-for="Input.Name" class="text-danger"></span>
                </div>

                <div class="form-group mb-3">
                    <label asp-for="Input.Description" class="control-label font-weight-bold">Description</label>
                    <textarea asp-for="Input.Description" class="form-control" rows="4" placeholder="Enter detailed description..."></textarea>
                    <span asp-validation-for="Input.Description" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <button type="submit" class="btn btn-primary">Create</button>
                    <a asp-page="/Manager/Index" class="btn btn-secondary">Cancel</a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
