@page "{id:int}"
@model DataLabelingSupportSystem.UI.Pages.Manager.EditProjectModel
@{
    ViewData["Title"] = "Edit Project";
}

<!-- Header (dash-card like /Manager, no stat cards) -->
<div class="dash-card mb-3">
    <div class="dash-card-h d-flex justify-content-between align-items-center">
        <div>
            <div class="fw-semibold" style="font-size:18px;">Edit Project</div>
            <div class="text-muted" style="font-size:13px;">Update name and description for this project.</div>
        </div>

        <div class="d-flex gap-2">
            <a asp-page="/Manager/Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
            <a asp-page="/Manager/Details" asp-route-id="@Model.Input.Id" class="btn btn-outline-primary">
                <i class="bi bi-eye"></i> Details
            </a>
        </div>
    </div>
</div>

<!-- Form card -->
<div class="dash-card" style="max-width: 980px;">
    <div class="dash-card-h d-flex justify-content-between align-items-center">
        <div class="fw-semibold">Project Information</div>
        <small class="text-muted">ID: @Model.Input.Id</small>
    </div>

    <div class="dash-card-b">
        <form method="post">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <input type="hidden" asp-for="Input.Id" />

            <div class="row g-3">
                <div class="col-12">
                    <label asp-for="Input.Name" class="form-label fw-semibold">Project Name</label>
                    <input asp-for="Input.Name" class="form-control" />
                    <span asp-validation-for="Input.Name" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <label asp-for="Input.Description" class="form-label fw-semibold">Description</label>
                    <textarea asp-for="Input.Description" class="form-control" rows="6"></textarea>
                    <span asp-validation-for="Input.Description" class="text-danger"></span>
                </div>

                <div class="col-12">
                    <div class="d-flex justify-content-end gap-2 pt-3" style="border-top:1px solid var(--dash-border);">
                        <a asp-page="/Manager/Index" class="btn btn-outline-secondary">Cancel</a>
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save2"></i> Save Changes
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
