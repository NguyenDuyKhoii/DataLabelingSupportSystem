@page "{id:int}"
@using System.Text.Json
@model DataLabelingSupportSystem.UI.Pages.Manager.DetailsModel
@{
    ViewData["Title"] = "Project Details: " + Model.Project.Name;
}

<!-- Header (dash-card like /Manager, no stat cards) -->
<div class="dash-card mb-3">
    <div class="dash-card-h d-flex justify-content-between align-items-center">
        <div>
            <div class="fw-semibold" style="font-size:18px;">@Model.Project.Name</div>
            <div class="text-muted" style="font-size:13px;">@Model.Project.Description</div>
        </div>

        <div class="d-flex gap-2">
            <a asp-page="/Manager/Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
            <a asp-page="/Manager/EditProject" asp-route-id="@Model.Project.Id" class="btn btn-outline-primary">
                <i class="bi bi-pencil"></i> Edit
            </a>
        </div>
    </div>
</div>

<!-- Status / meta (still dash-card, simple, no stat-card blocks) -->
<div class="dash-card mb-3">
    <div class="dash-card-b d-flex flex-wrap align-items-center justify-content-between gap-3">
        <div class="d-flex align-items-center gap-2">
            <span class="text-muted" style="font-size:12px;">Status</span>
            @if (Model.Project.Status == "New")
            {
                <span class="badge bg-primary">New</span>
            }
            else if (Model.Project.Status == "InProgress")
            {
                <span class="badge bg-warning text-dark">In Progress</span>
            }
            else
            {
                <span class="badge bg-success">Completed</span>
            }
        </div>

        <div class="text-muted" style="font-size:12px;">
            <i class="bi bi-calendar3 me-1"></i>
            Created: <span class="fw-semibold text-dark">@Model.Project.CreatedDate.ToString("dd/MM/yyyy")</span>
            <span class="mx-2">•</span>
            Labels: <span class="fw-semibold text-dark">@Model.Labels.Count</span>
            <span class="mx-2">•</span>
            Images: <span class="fw-semibold text-dark">@Model.ImageUrls.Count</span>
        </div>
    </div>
</div>

<!-- Tabs container (dash-card like Index) -->
<div class="dash-card">
    <div class="dash-card-h d-flex justify-content-between align-items-center">
        <div class="fw-semibold">Manage</div>

        <ul class="nav nav-pills gap-2 mb-0" id="myTab" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="labels-tab" data-bs-toggle="tab" data-bs-target="#labels"
                        type="button" role="tab" aria-controls="labels" aria-selected="true">
                    <i class="bi bi-tags"></i> Labels
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="images-tab" data-bs-toggle="tab" data-bs-target="#images"
                        type="button" role="tab" aria-controls="images" aria-selected="false">
                    <i class="bi bi-images"></i> Image & Task Management
                </button>
            </li>
        </ul>
    </div>

    <div class="dash-card-b">
        <div class="tab-content" id="myTabContent">

            <!-- ================= LABELS TAB ================= -->
            <div class="tab-pane fade show active" id="labels" role="tabpanel" aria-labelledby="labels-tab">
                <div class="row g-3">

                    <!-- Add label -->
                    <div class="col-12 col-lg-4">
                        <div class="p-3" style="background:#fff;border:1px solid var(--dash-border);border-radius:18px;">
                            <div class="fw-semibold mb-3">Add new label</div>

                            <form asp-page-handler="AddLabel" method="post">
                                <input type="hidden" name="id" value="@Model.Project.Id" />

                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Label name</label>
                                    <input asp-for="NewLabel.Name" class="form-control" placeholder="e.g. Dog..." />
                                    <span asp-validation-for="NewLabel.Name" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label fw-semibold">Display color</label>
                                    <div class="d-flex align-items-center gap-2">
                                        <input type="color" asp-for="NewLabel.Color" class="form-control form-control-color" title="Choose color" />
                                        <small class="text-muted">Choose a color</small>
                                    </div>
                                </div>

                                <button type="submit" class="btn btn-primary w-100">
                                    <i class="bi bi-check2-circle"></i> Save label
                                </button>
                            </form>
                        </div>
                    </div>

                    <!-- Labels list -->
                    <div class="col-12 col-lg-8">
                        <div style="background:#fff;border:1px solid var(--dash-border);border-radius:18px;overflow:hidden;">
                            <div class="d-flex justify-content-between align-items-center px-3 pt-3 pb-2"
                                 style="border-bottom:1px solid var(--dash-border);">
                                <div class="fw-semibold">Current labels</div>
                                <div class="text-muted" style="font-size:12px;">@Model.Labels.Count items</div>
                            </div>

                            @if (Model.Labels.Count == 0)
                            {
                                <div class="text-center text-muted py-5">
                                    No labels yet. Add your first label on the left!
                                </div>
                            }
                            else
                            {
                                <div class="table-responsive">
                                    <table class="table align-middle mb-0">
                                        <thead>
                                            <tr>
                                                <th style="width:60px;"></th>
                                                <th>Label Name</th>
                                                <th style="width:160px;">Color</th>
                                                <th style="width:220px;">Actions</th>
                                            </tr>
                                        </thead>
                                        <tbody>
                                            @foreach (var label in Model.Labels)
                                            {
                                                <tr>
                                                    <td>
                                                        <span class="rounded-circle border d-inline-block"
                                                              style="width:18px;height:18px;background-color:@label.Color;"></span>
                                                    </td>
                                                    <td class="fw-semibold">@label.Name</td>
                                                    <td class="text-muted">@label.Color</td>
                                                    <td>
                                                        <div class="d-flex gap-2">
                                                            <button type="button" class="btn btn-sm btn-outline-primary"
                                                                    data-bs-toggle="modal" data-bs-target="#editModal"
                                                                    onclick='setEditData(@label.Id, @Html.Raw(JsonSerializer.Serialize(label.Name)), @Html.Raw(JsonSerializer.Serialize(label.Color)))'>
                                                                <i class="bi bi-pencil"></i> Edit
                                                            </button>

                                                            <form asp-page-handler="DeleteLabel" method="post" class="d-inline"
                                                                  onsubmit="return confirm('Are you sure you want to delete this label?');">
                                                                <input type="hidden" name="labelId" value="@label.Id" />
                                                                <input type="hidden" name="projectId" value="@Model.Project.Id" />
                                                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                                                    <i class="bi bi-trash"></i> Delete
                                                                </button>
                                                            </form>
                                                        </div>
                                                    </td>
                                                </tr>
                                            }
                                        </tbody>
                                    </table>
                                </div>
                            }
                        </div>
                    </div>

                </div>
            </div>

            <!-- ================= IMAGES TAB ================= -->
            <div class="tab-pane fade" id="images" role="tabpanel" aria-labelledby="images-tab">

                <!-- Upload -->
                <div class="p-3 mb-3" style="background:#fff;border:1px solid var(--dash-border);border-radius:18px;">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <div class="fw-semibold">
                            <i class="bi bi-cloud-upload me-1"></i> Upload dataset images
                        </div>
                        <small class="text-muted">Multiple files supported</small>
                    </div>

                    <form method="post" enctype="multipart/form-data" asp-page-handler="UploadImages">
                        <input type="hidden" name="id" value="@Model.Project.Id" />

                        <div class="input-group">
                            <input type="file" asp-for="UploadFiles" class="form-control" multiple accept="image/*" />
                            <button class="btn btn-success" type="submit">
                                <i class="bi bi-upload"></i> Upload
                            </button>
                        </div>

                        <small class="text-muted fst-italic">Supported: .jpg, .jpeg, .png</small>
                    </form>
                </div>

                <!-- Grid -->
                <div class="p-3" style="background:#fff;border:1px solid var(--dash-border);border-radius:18px;">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <div class="fw-semibold">
                            <i class="bi bi-images me-1"></i> Images in this project
                        </div>
                        <small class="text-muted">@Model.ImageUrls.Count items</small>
                    </div>

                    <div class="row g-3">
                        @if (Model.ImageUrls != null && Model.ImageUrls.Count > 0)
                        {
                            @foreach (var imgUrl in Model.ImageUrls)
                            {
                                <div class="col-6 col-md-4 col-lg-3">
                                    <div style="border:1px solid var(--dash-border);border-radius:18px;overflow:hidden;background:#fff;">
                                        <a href="@imgUrl" target="_blank" class="d-block">
                                            <img src="@imgUrl" alt="Data Item"
                                                 style="height:160px;width:100%;object-fit:cover;" />
                                        </a>
                                        <div class="p-2 text-center">
                                            <small class="text-muted">Image Cloud</small>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="col-12">
                                <div class="alert alert-secondary text-center py-5 mb-0">
                                    <div class="display-6">📂</div>
                                    <p class="text-muted mb-0">No images have been uploaded yet.</p>
                                    <p class="small mb-0">Choose images above and click Upload.</p>
                                </div>
                            </div>
                        }
                    </div>
                </div>

            </div>
            <hr class="my-5" />

            <!-- TASKS SECTION -->
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h5>📋 Tasks in this project (@Model.Tasks.Count)</h5>
                <button type="button" class="btn btn-primary" data-bs-toggle="modal" data-bs-target="#createTaskModal">
                    <i class="bi bi-plus-circle"></i> Create New Task
                </button>
            </div>
            
            <div class="card shadow-sm">
                <div class="card-body p-0">
                    <div class="table-responsive">
                        <table class="table table-hover mb-0">
                            <thead class="bg-light">
                                <tr>
                                    <th># Task ID</th>
                                    <th>Annotator</th>
                                    <th>Assigned Images</th>
                                    <th>Status</th>
                                    <th>Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Tasks != null && Model.Tasks.Count > 0)
                                {
                                    @foreach (var task in Model.Tasks)
                                    {
                                        <tr>
                                            <td><strong>#@task.TaskId</strong></td>
                                            <td>
                                                <i class="bi bi-person-badge"></i> @task.AnnotatorName
                                            </td>
                                            <td>
                                                <span class="badge bg-info text-dark">@task.ImageCount Images</span>
                                            </td>
                                            <td>
                                                @{
                                                    string badgeClass = task.Status.ToString() switch
                                                    {
                                                        "Assigned" => "bg-secondary",
                                                        "InProgress" => "bg-primary",
                                                        "Completed" => "bg-success",
                                                        _ => "bg-light text-dark"
                                                    };
                                                }
                                                <span class="badge @badgeClass">@task.Status</span>
                                            </td>
                                            <td>
                                                <button class="btn btn-sm btn-outline-secondary">View Details</button>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="5" class="text-center text-muted py-4">
                                            No tasks found. Click "Create New Task" to begin.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Create Task Modal -->
<div class="modal fade" id="createTaskModal" tabindex="-1" aria-labelledby="createTaskModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="createTaskModalLabel">📝 Create New Task</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-page-handler="CreateTask" method="post">
                <div class="modal-body">
                    <input type="hidden" name="projectId" value="@Model.Project.Id" />
                    
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Select Annotator <span class="text-danger">*</span></label>
                            <select name="annotatorId" class="form-select" required>
                                <option value="">-- Select an Annotator --</option>
                                @if (Model.Annotators != null)
                                {
                                    @foreach (var annotator in Model.Annotators)
                                    {
                                        <option value="@annotator.UserId">@annotator.Name (@annotator.Username)</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Select Images to Assign <span class="text-danger">*</span></label>
                            <div class="bg-light p-3 border rounded" style="max-height: 400px; overflow-y: auto;">
                                <div class="row g-2">
                                    @if (Model.ProjectDataItems != null && Model.ProjectDataItems.Count > 0)
                                    {
                                        @foreach (var item in Model.ProjectDataItems)
                                        {
                                            <div class="col-4 col-md-3">
                                                <div class="card h-100 position-relative border">
                                                    <div class="position-absolute top-0 start-0 m-1 z-1">
                                                        <input class="form-check-input" type="checkbox" name="dataItemIds" value="@item.DataItemId" id="chk_@item.DataItemId" style="width: 20px; height: 20px;">
                                                    </div>
                                                    <label for="chk_@item.DataItemId" class="w-100 h-100 m-0 cursor-pointer d-flex flex-column">
                                                        <img src="@item.ImagePath" class="card-img-top flex-grow-1" style="object-fit: cover; height: 100px;" alt="Data Item">
                                                    </label>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="col-12 text-center text-muted">
                                            No images available in this project.
                                        </div>
                                    }
                                </div>
                            </div>
                            <small class="text-muted">Select at least one image.</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Create & Assign Task</button>
                </div>
            </form>

        </div>
    </div>
</div>

<!-- Edit Label Modal -->
<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title fw-semibold" id="editModalLabel">
                    <i class="bi bi-pencil-square me-2"></i> Edit label
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form asp-page-handler="UpdateLabel" method="post">
                <div class="modal-body">
                    <input type="hidden" name="projectId" value="@Model.Project.Id" />
                    <input type="hidden" name="labelId" id="editLabelId" />

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Label name</label>
                        <input type="text" class="form-control" name="labelName" id="editLabelName" required />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-semibold">Display color</label>
                        <div class="d-flex align-items-center gap-2">
                            <input type="color" class="form-control form-control-color" name="labelColor" id="editLabelColor" />
                            <small class="text-muted">Choose a color</small>
                        </div>
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save2"></i> Save changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function setEditData(id, name, color) {
            document.getElementById('editLabelId').value = id;
            document.getElementById('editLabelName').value = name;
            document.getElementById('editLabelColor').value = color;
        }
    </script>
}
