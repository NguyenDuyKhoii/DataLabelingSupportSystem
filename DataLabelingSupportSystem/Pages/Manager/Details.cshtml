@page "{id:int}"
@using System.Text.Json
@model DataLabelingSupportSystem.UI.Pages.Manager.DetailsModel
@{
    ViewData["Title"] = "Project Details: " + Model.Project.Name;
}

<div class="dash-card mb-4">
    <div class="dash-card-h d-flex justify-content-between align-items-center py-3">
        <div>
            <div class="fs-4 fw-bold" style="color: #0b3b6d; letter-spacing: -0.5px;">@Model.Project.Name</div>
            <div class="text-muted" style="font-size:14px;">@Model.Project.Description</div>
        </div>

        <div class="d-flex gap-2">
            <a asp-page-handler="ExportYolo" asp-route-id="@Model.Project.Id" class="btn btn-action btn-outline-success">
                <i class="bi bi-download"></i> Export YOLO
            </a>
            <a asp-page="/Manager/Index" class="btn btn-action btn-outline-secondary">
                <i class="bi bi-arrow-left"></i> Back
            </a>
            <a asp-page="/Manager/EditProject" asp-route-id="@Model.Project.Id" class="btn btn-action btn-outline-primary">
                <i class="bi bi-pencil-square"></i> Edit
            </a>
        </div>
    </div>
</div>

<div class="dash-card mb-4">
    <div class="dash-card-b d-flex flex-wrap align-items-center justify-content-between py-3">
        <div class="d-flex align-items-center gap-3">
            <span class="text-muted fw-bold text-uppercase small" style="letter-spacing: 1px;">Status</span>
            @if (Model.Project.Status == "New")
            {
                <span class="badge badge-soft-primary">New</span>
            }
            else if (Model.Project.Status == "InProgress")
            {
                <span class="badge badge-soft-warning">In Progress</span>
            }
            else
            {
                <span class="badge badge-soft-success">Completed</span>
            }
        </div>

        <div class="text-muted d-flex align-items-center gap-4" style="font-size:13px;">
            <div>
                <i class="bi bi-calendar3 me-1 text-primary"></i>
                Created: <span class="fw-bold text-dark">@Model.Project.CreatedDate.ToString("dd/MM/yyyy")</span>
            </div>
            <div>
                <i class="bi bi-tags-fill me-1 text-indigo"></i>
                Labels: <span class="fw-bold text-dark">@Model.Labels.Count</span>
            </div>
            <div>
                <i class="bi bi-images me-1 text-success"></i>
                Images: <span class="fw-bold text-dark">@Model.ImageUrls.Count</span>
            </div>
        </div>
    </div>
</div>

<div class="dash-card">
    <div class="dash-card-h d-flex justify-content-between align-items-center">
        <div class="fw-semibold">Manage</div>

        <ul class="nav nav-pills gap-2 mb-0" id="myTab" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="dashboard-tab" data-bs-toggle="tab" data-bs-target="#dashboard"
                        type="button" role="tab" aria-controls="dashboard" aria-selected="true">
                    <i class="bi bi-graph-up"></i> Dashboard
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="labels-tab" data-bs-toggle="tab" data-bs-target="#labels"
                        type="button" role="tab" aria-controls="labels" aria-selected="false">
                    <i class="bi bi-tags"></i> Labels
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="images-tab" data-bs-toggle="tab" data-bs-target="#images"
                        type="button" role="tab" aria-controls="images" aria-selected="false">
                    <i class="bi bi-images"></i> Image & Task Management
                </button>
            </li>
        </ul>
    </div>

    <div class="dash-card-b">
        <div class="tab-content" id="myTabContent">

            <div class="tab-pane fade show active" id="dashboard" role="tabpanel" aria-labelledby="dashboard-tab">
                <div class="row g-4">
                    <div class="col-md-5">
                        <div class="stat-card stat-card-indigo text-center">
                            <div class="stat-title">Project Completion</div>
                            <div class="stat-value text-success" style="font-size: 42px;">
                                @(Model.Stats?.TotalImages > 0 ? (int)Math.Round((double)Model.Stats.ApprovedImages / Model.Stats.TotalImages * 100) : 0)%
                            </div>
                            <div class="stat-meta">@Model.Stats?.ApprovedImages / @Model.Stats?.TotalImages images approved</div>
                            <div class="progress mt-3" style="height: 8px; border-radius: 4px;">
                                <div class="progress-bar bg-success" role="progressbar" 
                                     style="width: @(Model.Stats?.TotalImages > 0 ? (int)Math.Round((double)Model.Stats.ApprovedImages / Model.Stats.TotalImages * 100) : 0)%"></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-7">
                        <div class="stat-card">
                            <div class="stat-title mb-3">Status Breakdown</div>
                            <div class="row text-center mt-2">
                                <div class="col-3">
                                    <div class="stat-icon mx-auto bg-success-soft" style="background: rgba(16, 185, 129, 0.1); color: #10b981;">
                                        <i class="bi bi-check-circle"></i>
                                    </div>
                                    <div class="h4 fw-bold mb-0 text-success">@Model.Stats?.ApprovedImages</div>
                                    <div class="stat-meta">Approved</div>
                                </div>
                                <div class="col-3">
                                    <div class="stat-icon mx-auto" style="background: rgba(245, 158, 11, 0.1); color: #f59e0b;">
                                        <i class="bi bi-clock-history"></i>
                                    </div>
                                    <div class="h4 fw-bold mb-0 text-warning">@Model.Stats?.PendingImages</div>
                                    <div class="stat-meta">Pending</div>
                                </div>
                                <div class="col-3">
                                    <div class="stat-icon mx-auto" style="background: rgba(239, 68, 68, 0.1); color: #ef4444;">
                                        <i class="bi bi-x-circle"></i>
                                    </div>
                                    <div class="h4 fw-bold mb-0 text-danger">@Model.Stats?.RejectedImages</div>
                                    <div class="stat-meta">Rejected</div>
                                </div>
                                <div class="col-3">
                                    <div class="stat-icon mx-auto" style="background: rgba(100, 116, 139, 0.1); color: #64748b;">
                                        <i class="bi bi-slash-circle"></i>
                                    </div>
                                    <div class="h4 fw-bold mb-0 text-secondary">@Model.Stats?.UnassignedImages</div>
                                    <div class="stat-meta">Untouched</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="row g-4 mt-1">
                    <div class="col-md-6">
                        <div class="dash-section shadow-sm">
                            <div class="dash-section-h" style="background: #f8fafc;">
                                <span><i class="bi bi-pie-chart-fill me-2 text-indigo"></i>Label Distribution</span>
                            </div>
                            <div class="dash-section-b">
                                <div style="height: 300px;">
                                    <canvas id="labelChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="dash-section shadow-sm">
                            <div class="dash-section-h" style="background: #f8fafc;">
                                <span><i class="bi bi-activity me-2 text-primary"></i>Daily Throughput (Approved)</span>
                            </div>
                            <div class="dash-section-b">
                                <div style="height: 300px;">
                                    <canvas id="progressChart"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="labels" role="tabpanel" aria-labelledby="labels-tab">
                <div class="row g-4">
                    <div asp-validation-summary="All" class="text-danger mb-2"></div>
                    <div class="col-12 col-lg-4">
                        <div class="dash-section shadow-sm">
                            <div class="dash-section-h" style="background: #f8fafc;">
                                <span><i class="bi bi-plus-circle-fill me-2 text-primary"></i>Add New Label</span>
                            </div>
                            <div class="dash-section-b">
                                <form asp-page-handler="AddLabel" method="post">
                                    <input type="hidden" name="id" value="@Model.Project.Id" />

                                    <div class="mb-3">
                                        <label class="form-label fw-bold small text-uppercase" style="color: #64748b;">Label Name</label>
                                        <input asp-for="NewLabel.Name" class="form-control px-3" placeholder="e.g. Car, Person..." style="border-radius: 10px;" />
                                        <span asp-validation-for="NewLabel.Name" class="text-danger"></span>
                                    </div>

                                    <div class="mb-3">
                                        <label class="form-label fw-bold small text-uppercase" style="color: #64748b;">Display Color</label>
                                        <div class="d-flex align-items-center gap-3">
                                            <input type="color" asp-for="NewLabel.Color" class="form-control form-control-color" style="width: 50px; height: 50px; border-radius: 10px;" title="Choose color" />
                                            <div class="text-muted small">Choose a recognizable color for this label.</div>
                                        </div>
                                    </div>

                                    <button type="submit" class="btn btn-primary w-100 py-2 fw-bold" style="border-radius: 10px;">
                                        <i class="bi bi-plus-lg me-1"></i> Save Label
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>

                    <div class="col-12 col-lg-8">
                        <div class="dash-section shadow-sm overflow-hidden">
                            <div class="dash-section-h d-flex justify-content-between align-items-center" style="background: #f8fafc;">
                                <span><i class="bi bi-list-ul me-2 text-indigo"></i>Current Labels</span>
                                <span class="badge bg-light text-dark fw-normal border">@Model.Labels.Count items</span>
                            </div>

                            <div class="dash-section-b p-0">
                                @if (Model.Labels.Count == 0)
                                {
                                    <div class="text-center text-muted py-5">
                                        <i class="bi bi-tag display-4 d-block mb-3 opacity-25"></i>
                                        No labels yet. Add your first label on the left!
                                    </div>
                                }
                                else
                                {
                                    <div class="table-responsive">
                                        <table class="table align-middle mb-0">
                                            <thead>
                                                <tr>
                                                    <th style="width:70px;"></th>
                                                    <th>Label Name</th>
                                                    <th style="width:160px;">Hex Code</th>
                                                    <th style="width:200px;" class="text-end px-4">Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var label in Model.Labels)
                                                {
                                                    <tr>
                                                        <td class="text-center">
                                                            <span class="rounded-pill d-inline-block"
                                                                  style="width:24px;height:24px;background-color:@label.Color; border: 2px solid #fff; box-shadow: 0 0 0 1px #e2e8f0;"></span>
                                                        </td>
                                                        <td>
                                                            <span class="fw-bold" style="color: @label.Color;">@label.Name</span>
                                                        </td>
                                                        <td><code>@label.Color.ToUpper()</code></td>
                                                        <td class="text-end px-4">
                                                            <div class="d-flex gap-2 justify-content-end">
                                                                <button type="button" class="btn btn-action btn-outline-primary"
                                                                        data-bs-toggle="modal" data-bs-target="#editModal"
                                                                        onclick='setEditData(@label.Id, @Html.Raw(JsonSerializer.Serialize(label.Name)), @Html.Raw(JsonSerializer.Serialize(label.Color)))'>
                                                                    <i class="bi bi-pencil-square"></i> Edit
                                                                </button>

                                                                <form asp-page-handler="DeleteLabel" method="post" class="d-inline"
                                                                      onsubmit="return confirm('Are you sure you want to delete this label?');">
                                                                    <input type="hidden" name="labelId" value="@label.Id" />
                                                                    <input type="hidden" name="projectId" value="@Model.Project.Id" />
                                                                    <button type="submit" class="btn btn-action btn-outline-danger">
                                                                        <i class="bi bi-trash3"></i>
                                                                    </button>
                                                                </form>
                                                            </div>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="tab-pane fade" id="images" role="tabpanel" aria-labelledby="images-tab">

                <div class="dash-section shadow-sm mb-4">
                    <div class="dash-section-h d-flex justify-content-between align-items-center" style="background: #f8fafc;">
                        <span><i class="bi bi-cloud-upload-fill me-2 text-primary"></i>Upload Dataset Images</span>
                        <div class="d-flex gap-2">
                            <button type="button" class="btn btn-action btn-outline-primary" onclick="document.getElementById('fileInput').click();">
                                <i class="bi bi-file-earmark-image"></i> Select Files
                            </button>
                            <button type="button" class="btn btn-action btn-outline-indigo" onclick="document.getElementById('folderInput').click();" 
                                    style="border-color: #6366f1; color: #6366f1;">
                                <i class="bi bi-folder2-open"></i> Select Folder
                            </button>
                        </div>
                    </div>
                    
                    <div class="dash-section-b">
                        <form method="post" enctype="multipart/form-data" asp-page-handler="UploadImages" id="uploadForm">
                            <input type="hidden" name="id" value="@Model.Project.Id" />
                            
                            <!-- Hidden inputs for file/folder selection -->
                            <input type="file" asp-for="UploadFiles" id="fileInput" class="d-none" multiple accept="image/*" onchange="this.form.submit();" />
                            <input type="file" name="UploadFiles" id="folderInput" class="d-none" webkitdirectory mozdirectory msdirectory odirectory directory onchange="this.form.submit();" />

                            <div class="upload-zone text-center p-5" onclick="document.getElementById('fileInput').click();">
                                <div class="stat-icon mx-auto bg-primary-soft mb-3" style="background: rgba(79, 70, 229, 0.1); color: #4f46e5; width: 64px; height: 64px; font-size: 28px;">
                                    <i class="bi bi-cloud-arrow-up-fill"></i>
                                </div>
                                <h5 class="fw-bold mb-1">Drag and drop images here</h5>
                                <p class="text-muted mb-0">or click to browse from your computer</p>
                                <div class="mt-3">
                                    <span class="badge bg-light text-muted border px-2 py-1">JPG, PNG, JPEG supported</span>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>

                <div class="dash-section shadow-sm">
                    <div class="dash-section-h d-flex justify-content-between align-items-center" style="background: #f8fafc;">
                        <span><i class="bi bi-images me-2 text-indigo"></i>Images in this project</span>
                        <span class="badge bg-light text-dark fw-normal border">@Model.ImageUrls.Count items</span>
                    </div>

                    <div class="dash-section-b">
                        <div class="row g-4">
                            @if (Model.ImageUrls != null && Model.ImageUrls.Count > 0)
                            {
                                @foreach (var imgUrl in Model.ImageUrls)
                                {
                                    <div class="col-6 col-md-4 col-lg-3">
                                        <div class="image-card">
                                            <a href="@imgUrl" target="_blank" class="d-flex align-items-center justify-content-center overflow-hidden bg-light" style="height: 240px;">
                                                <img src="@imgUrl" alt="Data Item" style="max-height: 100%; width: auto; max-width: 100%;" />
                                            </a>
                                            <div class="image-card-footer text-center">
                                                <small class="text-muted fw-bold d-flex align-items-center justify-content-center gap-1">
                                                    <i class="bi bi-hdd-network"></i> Cloud Hosted
                                                </small>
                                            </div>
                                        </div>
                                    </div>
                                }
                            }
                            else
                            {
                                <div class="col-12">
                                    <div class="text-center py-5 opacity-50">
                                        <i class="bi bi-folder-x display-1 d-block mb-3"></i>
                                        <p class="h5 mb-0">No images uploaded yet</p>
                                        <p class="small">Upload some images above to get started</p>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <hr class="my-5" />

                <div class="d-flex justify-content-between align-items-center mb-4 mt-2">
                    <div class="d-flex align-items-center gap-2">
                        <div style="width: 4px; height: 24px; background: var(--dash-primary); border-radius: 2px;"></div>
                        <h5 class="mb-0 fw-bold" style="color: #0b3b6d;">Tasks in this project</h5>
                        <span class="badge badge-soft-primary px-2">@Model.Tasks.Count Total</span>
                    </div>
                    <button type="button" class="btn btn-primary d-flex align-items-center gap-2 px-3" 
                            data-bs-toggle="modal" data-bs-target="#createTaskModal" style="border-radius: 10px;">
                        <i class="bi bi-plus-lg fs-5"></i> Create New Task
                    </button>
                </div>
                
                <div class="dash-surface shadow-sm mb-5">
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th style="width: 120px;" class="ps-4"># ID</th>
                                    <th>Annotator</th>
                                    <th>Assigned</th>
                                    <th style="width: 300px;">Progress</th> 
                                    <th style="width: 150px;">Status</th>
                                    <th style="width: 140px;" class="text-end pe-4">Action</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (Model.Tasks != null && Model.Tasks.Count > 0)
                                {
                                    @foreach (var task in Model.Tasks)
                                    {
                                        <tr>
                                            <td class="ps-4">
                                                <span class="fw-bold text-indigo">#@task.TaskId</span>
                                            </td>
                                            <td>
                                                <div class="d-flex align-items-center gap-2">
                                                    <div class="dash-avatar" style="width: 32px; height: 32px; font-size: 12px;">
                                                        @(task.AnnotatorName?.Substring(0, 1).ToUpper() ?? "A")
                                                    </div>
                                                    <span class="fw-semibold">@task.AnnotatorName</span>
                                                </div>
                                            </td>
                                            <td>
                                                <span class="badge badge-soft-primary">@task.ImageCount Images</span>
                                            </td>
                                            
                                            <td>
                                                @{
                                                    int total = task.ImageCount;
                                                    int approved = task.ApprovedCount;
                                                    int rejected = task.RejectedCount;
                                                    int pending = task.SubmittedCount - approved - rejected; 
                                                    if(pending < 0) pending = 0; 
                                                    if(pending + approved + rejected > total) pending = total - approved - rejected;

                                                    int approvedPct = total > 0 ? (int)Math.Min(100, Math.Round((double)approved / total * 100)) : 0;
                                                    int rejectedPct = total > 0 ? (int)Math.Min(100 - approvedPct, Math.Round((double)rejected / total * 100)) : 0;
                                                    int pendingPct = total > 0 ? (int)Math.Min(100 - approvedPct - rejectedPct, Math.Round((double)pending / total * 100)) : 0;
                                                    int totalProgressPct = approvedPct + rejectedPct + pendingPct;
                                                }
                                                
                                                <div class="d-flex justify-content-between align-items-center mb-1" style="font-size: 11px;">
                                                    <span class="text-muted fw-bold">@(approved + rejected + pending) / @total DONE</span>
                                                    <span class="fw-bold text-dark">@(totalProgressPct)%</span>
                                                </div>
                                                
                                                <div class="progress" style="height: 6px; border-radius: 3px; background: #f1f5f9;">
                                                    <div class="progress-bar bg-success" role="progressbar" style="width: @(approvedPct)%" title="Approved: @approved"></div>
                                                    <div class="progress-bar bg-warning" role="progressbar" style="width: @(pendingPct)%" title="Pending: @pending"></div>
                                                    <div class="progress-bar bg-danger" role="progressbar" style="width: @(rejectedPct)%" title="Rejected: @rejected"></div>
                                                </div>
                                            </td>
                                            <td>
                                                @if (task.Status.ToString() == "Completed")
                                                {
                                                    <span class="badge badge-soft-success">
                                                        <i class="bi bi-check-circle-fill me-1"></i> Completed
                                                    </span>
                                                }
                                                else if (task.Status.ToString() == "InProgress")
                                                {
                                                    <span class="badge badge-soft-warning">
                                                        <i class="bi bi-arrow-repeat me-1"></i> In Progress
                                                    </span>
                                                }
                                                else
                                                {
                                                    <span class="badge badge-soft-primary">
                                                        <i class="bi bi-bookmark-plus me-1"></i> Assigned
                                                    </span>
                                                }
                                            </td>
                                            <td class="pe-4 text-end">
                                                <a asp-page="/Manager/TaskDetails" asp-route-id="@task.TaskId" class="btn btn-action btn-outline-primary">
                                                    <i class="bi bi-eye-fill"></i> View
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                }
                                else
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-5"> 
                                            <i class="bi bi-inbox display-4 d-block mb-2 opacity-25"></i>
                                            No tasks found. Click "Create New Task" to begin.
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="createTaskModal" tabindex="-1" aria-labelledby="createTaskModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title" id="createTaskModalLabel">📝 Create New Task</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <form asp-page-handler="CreateTask" method="post">
                <div class="modal-body">
                    <input type="hidden" name="projectId" value="@Model.Project.Id" />
                    
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Select Annotator <span class="text-danger">*</span></label>
                            <select name="annotatorId" class="form-select" required>
                                <option value="">-- Select an Annotator --</option>
                                @if (Model.Annotators != null)
                                {
                                    @foreach (var annotator in Model.Annotators)
                                    {
                                        <option value="@annotator.UserId">@annotator.Name (@annotator.Username)</option>
                                    }
                                }
                            </select>
                        </div>
                    </div>
                    
                    <div class="row">
                        <div class="col-md-12">
                            <label class="form-label fw-bold">Select Images to Assign <span class="text-danger">*</span></label>
                            <div class="bg-light p-3 border rounded" style="max-height: 400px; overflow-y: auto;">
                                <div class="row g-2">
                                    @if (Model.ProjectDataItems != null && Model.ProjectDataItems.Count > 0)
                                    {
                                        @foreach (var item in Model.ProjectDataItems)
                                        {
                                            <div class="col-4 col-md-3">
                                                <div class="card h-100 position-relative border">
                                                    <div class="position-absolute top-0 start-0 m-1 z-1">
                                                        <input class="form-check-input" type="checkbox" name="dataItemIds" value="@item.DataItemId" id="chk_@item.DataItemId" style="width: 20px; height: 20px;">
                                                    </div>
                                                    <label for="chk_@item.DataItemId" class="w-100 h-100 m-0 cursor-pointer d-flex flex-column">
                                                        <img src="@item.ImagePath" class="card-img-top flex-grow-1" style="object-fit: cover; height: 100px;" alt="Data Item">
                                                    </label>
                                                </div>
                                            </div>
                                        }
                                    }
                                    else
                                    {
                                        <div class="col-12 text-center text-muted">
                                            No images available in this project.
                                        </div>
                                    }
                                </div>
                            </div>
                            <small class="text-muted">Select at least one image.</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary"><i class="bi bi-save"></i> Create & Assign Task</button>
                </div>
            </form>

        </div>
    </div>
</div>

<div class="modal fade" id="editModal" tabindex="-1" aria-labelledby="editModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius: 20px; border: none; overflow: hidden; box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25);">
            <div class="modal-header py-3 px-4" style="background: #f8fafc; border-bottom: 1px solid #e2e8f0;">
                <h5 class="modal-title fw-bold" id="editModalLabel" style="color: #0b3b6d;">
                    <i class="bi bi-pencil-square me-2 text-primary"></i>Edit Label
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <form asp-page-handler="UpdateLabel" method="post">
                <div class="modal-body p-4">
                    <input type="hidden" name="projectId" value="@Model.Project.Id" />
                    <input type="hidden" name="labelId" id="editLabelId" />

                    <div class="mb-4">
                        <label class="form-label fw-bold small text-uppercase" style="color: #64748b;">Label Name</label>
                        <input type="text" class="form-control px-3 py-2" name="labelName" id="editLabelName" required style="border-radius: 10px;" />
                    </div>

                    <div class="mb-2">
                        <label class="form-label fw-bold small text-uppercase" style="color: #64748b;">Display Color</label>
                        <div class="d-flex align-items-center gap-3">
                            <input type="color" class="form-control form-control-color" name="labelColor" id="editLabelColor" 
                                   style="width: 50px; height: 50px; border-radius: 10px;" />
                            <div class="text-muted small">Update the color for visual distinction in annotator view.</div>
                        </div>
                    </div>
                </div>

                <div class="modal-footer border-0 p-4 pt-0">
                    <button type="button" class="btn btn-light px-4" data-bs-toggle="modal" style="border-radius: 10px; font-weight: 600;">Cancel</button>
                    <button type="submit" class="btn btn-primary px-4 py-2" style="border-radius: 10px; font-weight: 600;">
                        <i class="bi bi-save2-fill me-1"></i> Save Changes
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        // Data from Model
        const labelData = @Html.Raw(JsonSerializer.Serialize(Model.Stats?.LabelDistribution ?? new()));
        const progressData = @Html.Raw(JsonSerializer.Serialize(Model.Stats?.DailyProgress ?? new()));

        // Label Distribution Chart
        const ctxLabel = document.getElementById('labelChart');
        if (ctxLabel) {
            new Chart(ctxLabel, {
                type: 'doughnut',
                data: {
                    labels: labelData.map(x => x.LabelName),
                    datasets: [{
                        data: labelData.map(x => x.Count),
                        backgroundColor: labelData.map(x => x.Color || '#cccccc'),
                        borderWidth: 1
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { position: 'bottom' }
                    }
                }
            });
        }

        // Progress Chart
        const ctxProgress = document.getElementById('progressChart');
        if (ctxProgress) {
            new Chart(ctxProgress, {
                type: 'line',
                data: {
                    labels: progressData.map(x => new Date(x.Date).toLocaleDateString()),
                    datasets: [{
                        label: 'Approved Items',
                        data: progressData.map(x => x.Count),
                        borderColor: '#0d6efd',
                        backgroundColor: 'rgba(13, 110, 253, 0.1)',
                        fill: true,
                        tension: 0.3
                    }]
                },
                options: {
                    maintainAspectRatio: false,
                    scales: {
                        y: { beginAtZero: true, ticks: { stepSize: 1 } }
                    }
                }
            });
        }

        function setEditData(id, name, color) {
            document.getElementById('editLabelId').value = id;
            document.getElementById('editLabelName').value = name;
            document.getElementById('editLabelColor').value = color;
        }
    </script>
}