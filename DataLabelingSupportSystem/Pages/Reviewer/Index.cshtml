@page
@model DataLabelingSupportSystem.UI.Pages.Reviewer.IndexModel
@{
    ViewData["Title"] = "Review Queue";

    var queue = Model.Queue ?? new List<DataLabelingSupportSystem.BLL.DTO.ReviewQueueItemDto>();
    int total = queue.Count;
    int pending = queue.Count(q => q.Status == "Submitted");
    int inReview = queue.Count(q => q.Status == "InReview");
    int approved = queue.Count(q => q.Status == "Approved");
    int rejected = queue.Count(q => q.Status == "Rejected");
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container py-4">

    <!-- Header -->
    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
        <div>
            <h3 class="mb-0"><i class="bi bi-clipboard-check me-2"></i>Review Queue</h3>
            <small class="text-muted">Review submitted annotations</small>
        </div>
        <div class="d-flex gap-2">
            @if (pending + inReview > 0)
            {
                var firstPendingId = queue.FirstOrDefault(q => q.Status == "Submitted" || q.Status == "InReview")?.SubmissionId;
                if (firstPendingId != null)
                {
                    <a asp-page="/Reviewer/Review" asp-route-submissionId="@firstPendingId" class="btn btn-primary btn-sm shadow-sm">
                        <i class="bi bi-play-circle me-1"></i> Review All Pending
                    </a>
                }
            }
        </div>
    </div>

    <!-- Stats bar -->
    <div class="row g-2 mb-3">
        <div class="col-6 col-md-3">
            <div class="card border-0 bg-light text-center py-2">
                <div class="fw-bold fs-5">@total</div>
                <small class="text-muted">Total</small>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 bg-primary bg-opacity-10 text-center py-2">
                <div class="fw-bold fs-5 text-primary">@pending</div>
                <small class="text-muted">Pending</small>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 bg-warning bg-opacity-10 text-center py-2">
                <div class="fw-bold fs-5 text-warning">@inReview</div>
                <small class="text-muted">In Review</small>
            </div>
        </div>
        <div class="col-6 col-md-3">
            <div class="card border-0 bg-success bg-opacity-10 text-center py-2">
                <div class="fw-bold fs-5 text-success">@approved</div>
                <small class="text-muted">Approved</small>
            </div>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">

            <!-- Anti-forgery token for fetch -->
            <form method="post" id="antiForgeryForm">
                @Html.AntiForgeryToken()
            </form>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="font-size: 0.9rem;">
                    <thead class="table-light">
                        <tr>
                            <th>Submission</th>
                            <th>TaskItem</th>
                            <th>Submitted By</th>
                            <th>Submitted At (UTC)</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (total == 0)
                        {
                            <tr>
                                <td colspan="6" class="text-center text-muted py-5">
                                    <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                                    No submissions in queue.
                                </td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in queue)
                            {
                                var badge = item.Status switch
                                {
                                    "Submitted" => "bg-primary",
                                    "InReview" => "bg-warning text-dark",
                                    "Approved" => "bg-success",
                                    "Rejected" => "bg-danger",
                                    _ => "bg-secondary"
                                };

                                <tr data-submission-id="@item.SubmissionId" data-status="@item.Status">
                                    <td class="fw-semibold">#@item.SubmissionId</td>
                                    <td>@item.TaskItemId</td>
                                    <td>@item.SubmittedByName</td>
                                    <td>@item.SubmittedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td><span class="badge rounded-pill @badge">@item.Status</span></td>
                                    <td class="text-end">
                                        <a asp-page="/Reviewer/Review"
                                           asp-route-submissionId="@item.SubmissionId"
                                           class="btn btn-outline-primary btn-sm me-1"
                                           data-bs-toggle="tooltip" title="View">
                                            <i class="bi bi-eye"></i>
                                        </a>

                                        @if (item.Status == "InReview")
                                        {
                                            <button type="button"
                                                    class="btn btn-success btn-sm btn-approve me-1"
                                                    data-bs-toggle="tooltip" title="Approve">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                            <button type="button"
                                                    class="btn btn-danger btn-sm btn-reject"
                                                    data-bs-toggle="tooltip" title="Reject">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<!-- Modal comment -->
<div class="modal fade" id="decisionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="decisionTitle">Decision</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="modalSubmissionId" />
                <input type="hidden" id="modalAction" />

                <div class="mb-2">
                    <label class="form-label">Comment (optional)</label>
                    <textarea class="form-control" id="modalComment" rows="4" placeholder="Write a short note..."></textarea>
                </div>

                <div class="alert alert-danger d-none" id="modalError"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" id="modalConfirmBtn">Confirm</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            // Init tooltips
            document.querySelectorAll('[data-bs-toggle="tooltip"]').forEach(
                el => new bootstrap.Tooltip(el)
            );

            const tokenInput = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]');
            const token = tokenInput ? tokenInput.value : null;

            async function postHandler(handler, formData) {
                const res = await fetch(`?handler=${handler}`, {
                    method: 'POST',
                    body: formData,
                    headers: token ? { 'RequestVerificationToken': token } : {}
                });

                const data = await res.json().catch(() => null);
                if (!res.ok || !data || data.ok !== true) {
                    const msg = (data && data.error) ? data.error : `Request failed (${res.status})`;
                    throw new Error(msg);
                }
                return data;
            }

            const modalEl = document.getElementById('decisionModal');
            const modal = modalEl ? new bootstrap.Modal(modalEl) : null;

            const titleEl = document.getElementById('decisionTitle');
            const submissionIdEl = document.getElementById('modalSubmissionId');
            const actionEl = document.getElementById('modalAction');
            const commentEl = document.getElementById('modalComment');
            const errorEl = document.getElementById('modalError');
            const confirmBtn = document.getElementById('modalConfirmBtn');

            function showError(msg) {
                errorEl.textContent = msg;
                errorEl.classList.remove('d-none');
            }
            function clearError() {
                errorEl.textContent = '';
                errorEl.classList.add('d-none');
            }

            document.addEventListener('click', async (e) => {
                const row = e.target.closest('tr[data-submission-id]');
                if (!row) return;

                const submissionId = row.getAttribute('data-submission-id');
                const status = row.getAttribute('data-status');

                // Approve opens modal
                if (e.target.closest('.btn-approve') && status === 'InReview') {
                    titleEl.textContent = 'Approve submission';
                    submissionIdEl.value = submissionId;
                    actionEl.value = 'Approve';
                    commentEl.value = '';
                    clearError();
                    confirmBtn.className = 'btn btn-success btn-sm';
                    confirmBtn.textContent = 'Approve';
                    modal.show();
                    return;
                }

                // Reject opens modal
                if (e.target.closest('.btn-reject') && status === 'InReview') {
                    titleEl.textContent = 'Reject submission';
                    submissionIdEl.value = submissionId;
                    actionEl.value = 'Reject';
                    commentEl.value = '';
                    clearError();
                    confirmBtn.className = 'btn btn-danger btn-sm';
                    confirmBtn.textContent = 'Reject';
                    modal.show();
                    return;
                }
            });

            confirmBtn.addEventListener('click', async () => {
                try {
                    clearError();

                    const submissionId = submissionIdEl.value;
                    const action = actionEl.value;
                    const comment = commentEl.value || '';

                    const fd = new FormData();
                    fd.append('submissionId', submissionId);
                    fd.append('comment', comment);

                    if (action === 'Approve') {
                        await postHandler('Approve', fd);
                    } else if (action === 'Reject') {
                        await postHandler('Reject', fd);
                    }

                    window.location.reload();
                } catch (err) {
                    showError(err.message || err);
                }
            });
        })();
    </script>
}
