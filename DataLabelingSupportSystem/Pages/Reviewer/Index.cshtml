@page
@model DataLabelingSupportSystem.UI.Pages.Reviewer.IndexModel
@{
    ViewData["Title"] = "Review Queue";
}

<div class="container py-4">

    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
        <div>
            <h3 class="mb-0">Review Queue</h3>
            <small class="text-muted">Review submitted annotations</small>
        </div>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">

            <!-- Anti-forgery token for fetch -->
            <form method="post" id="antiForgeryForm">
                @Html.AntiForgeryToken()
            </form>

            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Submission</th>
                            <th>TaskItem</th>
                            <th>Submitted By</th>
                            <th>Submitted At (UTC)</th>
                            <th>Status</th>
                            <th class="text-end">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Queue == null || Model.Queue.Count == 0)
                        {
                            <tr>
                                <td colspan="6" class="text-muted">No submissions in queue.</td>
                            </tr>
                        }
                        else
                        {
                            foreach (var item in Model.Queue)
                            {
                                var badge = item.Status switch
                                {
                                    "Submitted" => "bg-primary",
                                    "InReview" => "bg-warning text-dark",
                                    "Approved" => "bg-success",
                                    "Rejected" => "bg-danger",
                                    _ => "bg-secondary"
                                };

                                <tr data-submission-id="@item.SubmissionId" data-status="@item.Status">
                                    <td>#@item.SubmissionId</td>
                                    <td>@item.TaskItemId</td>
                                    <td>@item.SubmittedByName</td>
                                    <td>@item.SubmittedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                    <td><span class="badge @badge">@item.Status</span></td>
                                    <td class="text-end">
                                        <!-- ✅ View detail (always available for non-draft queue items) -->
                                        <a asp-page="/Reviewer/Review"
                                           asp-route-submissionId="@item.SubmissionId"
                                           class="btn btn-outline-primary btn-sm me-2">
                                            View
                                        </a>

                                        @if (item.Status == "Submitted")
                                        {
                                            <button type="button" class="btn btn-outline-secondary btn-sm btn-start-review">
                                                Start review
                                            </button>
                                        }
                                        else if (item.Status == "InReview")
                                        {
                                            <button type="button" class="btn btn-success btn-sm btn-approve me-2">
                                                Approve
                                            </button>
                                            <button type="button" class="btn btn-danger btn-sm btn-reject">
                                                Reject
                                            </button>
                                        }
                                        else
                                        {
                                            <span class="text-muted">—</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<!-- Modal comment -->
<div class="modal fade" id="decisionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="decisionTitle">Decision</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="modalSubmissionId" />
                <input type="hidden" id="modalAction" />

                <div class="mb-2">
                    <label class="form-label">Comment (optional)</label>
                    <textarea class="form-control" id="modalComment" rows="4" placeholder="Write a short note..."></textarea>
                </div>

                <div class="alert alert-danger d-none" id="modalError"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" id="modalConfirmBtn">Confirm</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            // Get antiforgery token from hidden input
            const tokenInput = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]');
            const token = tokenInput ? tokenInput.value : null;

            async function postHandler(handler, formData) {
                const res = await fetch(`?handler=${handler}`, {
                    method: 'POST',
                    body: formData,
                    headers: token ? { 'RequestVerificationToken': token } : {}
                });

                const data = await res.json().catch(() => null);
                if (!res.ok || !data || data.ok !== true) {
                    const msg = (data && data.error) ? data.error : `Request failed (${res.status})`;
                    throw new Error(msg);
                }
                return data;
            }

            // Bootstrap modal instance
            const modalEl = document.getElementById('decisionModal');
            const modal = modalEl ? new bootstrap.Modal(modalEl) : null;

            const titleEl = document.getElementById('decisionTitle');
            const submissionIdEl = document.getElementById('modalSubmissionId');
            const actionEl = document.getElementById('modalAction');
            const commentEl = document.getElementById('modalComment');
            const errorEl = document.getElementById('modalError');
            const confirmBtn = document.getElementById('modalConfirmBtn');

            function showError(msg) {
                errorEl.textContent = msg;
                errorEl.classList.remove('d-none');
            }
            function clearError() {
                errorEl.textContent = '';
                errorEl.classList.add('d-none');
            }

            document.addEventListener('click', async (e) => {
                const row = e.target.closest('tr[data-submission-id]');
                if (!row) return;

                const submissionId = row.getAttribute('data-submission-id');
                const status = row.getAttribute('data-status');

                // Start review
                if (e.target.closest('.btn-start-review')) {
                    try {
                        const fd = new FormData();
                        fd.append('submissionId', submissionId);
                        await postHandler('SetInReview', fd);
                        window.location.reload();
                    } catch (err) {
                        alert(err.message || err);
                    }
                    return;
                }

                // Approve opens modal
                if (e.target.closest('.btn-approve') && status === 'InReview') {
                    titleEl.textContent = 'Approve submission';
                    submissionIdEl.value = submissionId;
                    actionEl.value = 'Approve';
                    commentEl.value = '';
                    clearError();
                    confirmBtn.className = 'btn btn-success btn-sm';
                    confirmBtn.textContent = 'Approve';
                    modal.show();
                    return;
                }

                // Reject opens modal
                if (e.target.closest('.btn-reject') && status === 'InReview') {
                    titleEl.textContent = 'Reject submission';
                    submissionIdEl.value = submissionId;
                    actionEl.value = 'Reject';
                    commentEl.value = '';
                    clearError();
                    confirmBtn.className = 'btn btn-danger btn-sm';
                    confirmBtn.textContent = 'Reject';
                    modal.show();
                    return;
                }
            });

            confirmBtn.addEventListener('click', async () => {
                try {
                    clearError();

                    const submissionId = submissionIdEl.value;
                    const action = actionEl.value;
                    const comment = commentEl.value || '';

                    const fd = new FormData();
                    fd.append('submissionId', submissionId);
                    fd.append('comment', comment);

                    if (action === 'Approve') {
                        await postHandler('Approve', fd);
                    } else if (action === 'Reject') {
                        await postHandler('Reject', fd);
                    }

                    window.location.reload();
                } catch (err) {
                    showError(err.message || err);
                }
            });
        })();
    </script>
}