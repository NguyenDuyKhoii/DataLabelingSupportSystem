@page "{submissionId:int}"
@model DataLabelingSupportSystem.UI.Pages.Reviewer.ReviewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Review Submission";
    var d = Model.Detail;
    var jsonOpt = new JsonSerializerOptions(JsonSerializerDefaults.Web); // camelCase
}

<div class="container py-4">

    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
        <div>
            <h3 class="mb-0">Review Submission</h3>
            <small class="text-muted">
                @if (d != null)
                {
                    <span>Submission #@d.SubmissionId • TaskItem #@d.TaskItemId • Status: @d.Status</span>
                }
            </small>
        </div>

        <div class="d-flex gap-2">
            <a asp-page="/Reviewer/Index" class="btn btn-outline-secondary btn-sm">Back</a>
        </div>
    </div>

    @if (d == null)
    {
        <div class="alert alert-warning">No data.</div>
    }
    else
    {
        <div class="row g-3">
            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-body">

                        <!-- Image + overlay -->
                        <div id="imgWrap" style="position:relative; width:100%; max-width:100%;">
                            <img id="mainImg" src="@d.ImagePath" alt="Image"
                                 style="display:block; width:100%; height:auto; border-radius:8px; position:relative; z-index:1;" />
                            <div id="overlay" style="position:absolute; inset:0; z-index:2; pointer-events:none;"></div>
                        </div>

                        <div class="mt-2 small text-muted">
                            Boxes: <span id="boxCount"></span>
                        </div>

                        <!-- JSON payload (safe, no broken quotes) -->
                        <script id="boxesJson" type="application/json">
                            @Html.Raw(JsonSerializer.Serialize(d.Boxes, jsonOpt))
                        </script>

                        <script id="colorsJson" type="application/json">
                            @Html.Raw(JsonSerializer.Serialize(d.LabelColors, jsonOpt))
                        </script>

                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h6 class="mb-2">Info</h6>
                        <div class="small">
                            <div><strong>Submission:</strong> #@d.SubmissionId</div>
                            <div><strong>Submitted by:</strong> @d.SubmittedByName</div>
                            <div><strong>Submitted at (UTC):</strong> @d.SubmittedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</div>
                            <div><strong>Status:</strong> <span class="badge bg-secondary">@d.Status</span></div>
                        </div>

                        <hr />

                        @if (d.Boxes.Count > 0)
                        {
                            <h6 class="mb-2">Labels</h6>
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                @foreach (var grp in d.Boxes.GroupBy(b => b.LabelId).Select(g => g.First()))
                                {
                                    var color = d.LabelColors.ContainsKey(grp.LabelId) ? d.LabelColors[grp.LabelId] : "#00bcd4";
                                    <span class="badge" style="background-color: @color; color: #fff; font-size: 0.8rem;">
                                        @grp.LabelName
                                        <span class="ms-1 badge bg-light text-dark">@d.Boxes.Count(b => b.LabelId == grp.LabelId)</span>
                                    </span>
                                }
                            </div>
                            <hr />
                        }

                        <!-- Anti-forgery token for fetch -->
                        <form method="post" id="antiForgeryForm">
                            @Html.AntiForgeryToken()
                        </form>

                        <div class="d-grid gap-2">
                            @if (d.Status == "Submitted")
                            {
                                <button type="button" class="btn btn-outline-warning btn-sm" id="btnStartReview">
                                    Start review
                                </button>
                            }
                            else if (d.Status == "InReview")
                            {
                                <button type="button" class="btn btn-success btn-sm" id="btnApprove">
                                    Approve
                                </button>
                                <button type="button" class="btn btn-danger btn-sm" id="btnReject">
                                    Reject
                                </button>
                            }
                            else
                            {
                                <div class="text-muted small">This submission is read-only.</div>
                            }
                        </div>

                        <div class="alert alert-danger d-none mt-3" id="actionError"></div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Modal comment -->
<div class="modal fade" id="decisionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="decisionTitle">Decision</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="modalAction" />

                <div class="mb-2">
                    <label class="form-label">Comment (optional)</label>
                    <textarea class="form-control" id="modalComment" rows="4" placeholder="Write a short note..."></textarea>
                </div>

                <div class="alert alert-danger d-none" id="modalError"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" id="modalConfirmBtn">Confirm</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            // Read JSON safely from <script type="application/json">
            const boxes = JSON.parse(document.getElementById('boxesJson')?.textContent || '[]');
            const colors = JSON.parse(document.getElementById('colorsJson')?.textContent || '{}');

            const boxCountEl = document.getElementById('boxCount');
            if (boxCountEl) boxCountEl.textContent = boxes.length.toString();

            const img = document.getElementById('mainImg');
            const overlay = document.getElementById('overlay');

            function clearOverlay() {
                if (!overlay) return;
                overlay.innerHTML = '';
            }

            function drawBoxes() {
                if (!img || !overlay) return;

                // ensure overlay matches actual rendered image size
                overlay.style.width = img.clientWidth + 'px';
                overlay.style.height = img.clientHeight + 'px';

                const rect = img.getBoundingClientRect();
                const w = rect.width;
                const h = rect.height;

                clearOverlay();

                boxes.forEach(b => {
                    const div = document.createElement('div');
                    div.style.position = 'absolute';
                    div.style.left = (b.x * w) + 'px';
                    div.style.top = (b.y * h) + 'px';
                    div.style.width = (b.width * w) + 'px';
                    div.style.height = (b.height * h) + 'px';

                    // dictionary keys can be numbers or strings -> normalize
                    const key = (b.labelId != null) ? String(b.labelId) : '';
                    const c = colors[key] || colors[b.labelId] || '#00bcd4';

                    div.style.border = `2px solid ${c}`;
                    div.style.background = c + '22';
                    div.style.borderRadius = '6px';
                    div.style.boxSizing = 'border-box';

                    // Label name tag
                    if (b.labelName) {
                        const tag = document.createElement('span');
                        tag.textContent = b.labelName;
                        tag.style.cssText = `position:absolute;top:-18px;left:0;background:${c};color:#fff;font-size:10px;padding:1px 5px;border-radius:3px;white-space:nowrap;pointer-events:none;`;
                        div.appendChild(tag);
                    }

                    overlay.appendChild(div);
                });
            }

            function onImgReady() {
                drawBoxes();
                window.addEventListener('resize', drawBoxes);
            }

            if (img && img.complete) onImgReady();
            else if (img) img.addEventListener('load', onImgReady);

            // Actions
            const tokenInput = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]');
            const token = tokenInput ? tokenInput.value : null;

            function showActionError(msg) {
                const el = document.getElementById('actionError');
                if (!el) return;
                el.textContent = msg;
                el.classList.remove('d-none');
            }
            function clearActionError() {
                const el = document.getElementById('actionError');
                if (!el) return;
                el.textContent = '';
                el.classList.add('d-none');
            }

            async function postHandler(handler, formData) {
                const res = await fetch(`?handler=${handler}`, {
                    method: 'POST',
                    body: formData,
                    headers: token ? { 'RequestVerificationToken': token } : {}
                });

                const data = await res.json().catch(() => null);
                if (!res.ok || !data || data.ok !== true) {
                    const msg = (data && data.error) ? data.error : `Request failed (${res.status})`;
                    throw new Error(msg);
                }
                return data;
            }

            // Bootstrap modal
            const modalEl = document.getElementById('decisionModal');
            const modal = modalEl ? new bootstrap.Modal(modalEl) : null;
            const titleEl = document.getElementById('decisionTitle');
            const actionEl = document.getElementById('modalAction');
            const commentEl = document.getElementById('modalComment');
            const modalErrorEl = document.getElementById('modalError');
            const confirmBtn = document.getElementById('modalConfirmBtn');

            function showModalError(msg) {
                modalErrorEl.textContent = msg;
                modalErrorEl.classList.remove('d-none');
            }
            function clearModalError() {
                modalErrorEl.textContent = '';
                modalErrorEl.classList.add('d-none');
            }

            const submissionId = @RouteData.Values["submissionId"];

            const btnStart = document.getElementById('btnStartReview');
            if (btnStart) {
                btnStart.addEventListener('click', async () => {
                    try {
                        clearActionError();
                        const fd = new FormData();
                        fd.append('submissionId', submissionId);
                        await postHandler('SetInReview', fd);
                        window.location.reload();
                    } catch (err) {
                        showActionError(err.message || err);
                    }
                });
            }

            const btnApprove = document.getElementById('btnApprove');
            if (btnApprove) {
                btnApprove.addEventListener('click', () => {
                    titleEl.textContent = 'Approve submission';
                    actionEl.value = 'Approve';
                    commentEl.value = '';
                    clearModalError();
                    confirmBtn.className = 'btn btn-success btn-sm';
                    confirmBtn.textContent = 'Approve';
                    modal.show();
                });
            }

            const btnReject = document.getElementById('btnReject');
            if (btnReject) {
                btnReject.addEventListener('click', () => {
                    titleEl.textContent = 'Reject submission';
                    actionEl.value = 'Reject';
                    commentEl.value = '';
                    clearModalError();
                    confirmBtn.className = 'btn btn-danger btn-sm';
                    confirmBtn.textContent = 'Reject';
                    modal.show();
                });
            }

            confirmBtn?.addEventListener('click', async () => {
                try {
                    clearModalError();
                    const action = actionEl.value;
                    const comment = commentEl.value || '';

                    const fd = new FormData();
                    fd.append('submissionId', submissionId);
                    fd.append('comment', comment);

                    if (action === 'Approve') await postHandler('Approve', fd);
                    if (action === 'Reject') await postHandler('Reject', fd);

                    window.location.reload();
                } catch (err) {
                    showModalError(err.message || err);
                }
            });

        })();
    </script>
}