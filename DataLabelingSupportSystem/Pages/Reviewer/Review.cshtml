@page "{submissionId:int}"
@model DataLabelingSupportSystem.UI.Pages.Reviewer.ReviewModel
@using System.Text.Json
@{
    ViewData["Title"] = "Review Submission";
    var d = Model.Detail;
    var jsonOpt = new JsonSerializerOptions(JsonSerializerDefaults.Web); // camelCase
}

<div class="container py-4">

    <div class="d-flex flex-wrap align-items-center justify-content-between gap-2 mb-3">
        <div>
            <h3 class="mb-0">Review Submission</h3>
            <small class="text-muted">
                @if (d != null)
                {
                    <span>Submission #@d.SubmissionId • TaskItem #@d.TaskItemId • Status: @d.Status</span>
                }
            </small>
        </div>

        <div class="d-flex gap-2">
            <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm shadow-sm">
                <i class="bi bi-arrow-left"></i> Back
            </a>
        </div>
    </div>

    @if (d == null)
    {
        <div class="alert alert-warning">No data.</div>
    }
    else
    {
        <div class="row g-3">
            <div class="col-lg-8">
                <div class="card shadow-sm">
                    <div class="card-body">

                        <!-- Image + overlay -->
                        <div id="imgWrap" style="position:relative; width:100%; max-width:100%;">
                            <img id="mainImg" src="@d.ImagePath" alt="Image"
                                 style="display:block; width:100%; height:auto; border-radius:8px; position:relative; z-index:1;" />
                            <div id="overlay" style="position:absolute; inset:0; z-index:2; pointer-events:none;"></div>
                        </div>

                        <div class="mt-2 small text-muted">
                            Boxes: <span id="boxCount"></span>
                        </div>

                        <!-- JSON payload (safe, no broken quotes) -->
                        <script id="boxesJson" type="application/json">
                            @Html.Raw(JsonSerializer.Serialize(d.Boxes, jsonOpt))
                        </script>

                        <script id="colorsJson" type="application/json">
                            @Html.Raw(JsonSerializer.Serialize(d.LabelColors, jsonOpt))
                        </script>

                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card shadow-sm">
                    <div class="card-body">
                        <h6 class="mb-2">Info</h6>
                        <div class="small">
                            <div><strong>Submission:</strong> #@d.SubmissionId</div>
                            <div><strong>Submitted by:</strong> @d.SubmittedByName</div>
                            <div><strong>Submitted at (UTC):</strong> @d.SubmittedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</div>
                            <div><strong>Status:</strong> <span class="badge bg-secondary">@d.Status</span></div>
                        </div>

                        <hr />

                        <div class="alert alert-info py-2 mb-3 shadow-sm border-0" style="font-size: 12px; background: #eef2ff; color: #4338ca;">
                            <i class="bi bi-magic me-1"></i> <strong>Continuous Mode</strong>: Jumping to next image after decision.
                        </div>

                        <hr />

                        @if (d.Boxes.Count > 0)
                        {
                            <h6 class="mb-2">Labels</h6>
                            <div class="d-flex flex-wrap gap-2 mb-3">
                                @foreach (var grp in d.Boxes.GroupBy(b => b.LabelId).Select(g => g.First()))
                                {
                                    var color = d.LabelColors.ContainsKey(grp.LabelId) ? d.LabelColors[grp.LabelId] : "#00bcd4";
                                    <span class="badge" style="background-color: @color; color: #fff; font-size: 0.8rem;">
                                        @grp.LabelName
                                        <span class="ms-1 badge bg-light text-dark">@d.Boxes.Count(b => b.LabelId == grp.LabelId)</span>
                                    </span>
                                }
                            </div>
                            <hr />
                        }

                        <!-- Anti-forgery token for fetch -->
                        <form method="post" id="antiForgeryForm">
                            @Html.AntiForgeryToken()
                        </form>

                        <div class="d-grid gap-2">
                            @if (User.IsInRole("Reviewer"))
                            {
                                @if (d.Status == "Submitted")
                                {
                                    <button type="button" class="btn btn-outline-warning btn-sm" id="btnStartReview">
                                        Start review
                                    </button>
                                }
                                else if (d.Status == "InReview")
                                {
                                    <button type="button" class="btn btn-success btn-sm" id="btnApprove">
                                        Approve
                                    </button>
                                    <button type="button" class="btn btn-danger btn-sm" id="btnReject">
                                        Reject
                                    </button>
                                }
                                else
                                {
                                    <div class="text-muted small border p-2 rounded text-center">This submission is read-only.</div>
                                }
                            }
                            else
                            {
                                <div class="alert alert-info py-2 mb-0" style="font-size: 13px;">
                                    <i class="bi bi-info-circle me-1"></i> You are viewing this result as a Manager.
                                </div>
                            }
                        </div>

                        <div class="alert alert-danger d-none mt-3" id="actionError"></div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

<!-- Modal comment -->
<div class="modal fade" id="decisionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg" style="border-radius: 20px;">
            <div class="modal-header border-0 pb-0">
                <h5 class="modal-title fw-bold" id="decisionTitle" style="color: #0f172a;">Decision</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body py-4">
                <input type="hidden" id="modalAction" />

                <div id="modalIconContainer" class="d-flex align-items-center mb-3">
                    <div id="modalIconBg" class="p-3 rounded-circle me-3">
                        <i id="modalIcon" class="bi fs-3"></i>
                    </div>
                    <div>
                        <p id="modalMainText" class="mb-0 fw-semibold text-dark">Processing Decision...</p>
                        <p id="modalSubText" class="text-muted small mb-0">Please provide a reason if necessary.</p>
                    </div>
                </div>

                <div class="mb-2">
                    <label class="form-label fw-bold small text-muted">Comment (optional)</label>
                    <textarea class="form-control border-0 bg-light p-3" id="modalComment" rows="3" placeholder="Write a short note..." style="border-radius: 12px;"></textarea>
                </div>

                <div class="alert alert-danger d-none mt-3" id="modalError"></div>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button type="button" class="btn btn-light px-4 fw-bold" data-bs-dismiss="modal" style="border-radius: 12px;">Cancel</button>
                <button type="button" class="btn px-4 fw-bold shadow-sm" id="modalConfirmBtn" style="border-radius: 12px;">Confirm</button>
            </div>
        </div>
    </div>
</div>

<!-- Toast Container for Feedback -->
<div class="toast-container position-fixed bottom-0 end-0 p-3" style="z-index: 2000;">
    <div id="feedbackToast" class="toast align-items-center border-0 shadow-lg" role="alert" aria-live="assertive" aria-atomic="true" style="border-radius: 15px;">
        <div class="d-flex p-2">
            <div class="toast-body d-flex align-items-center gap-3">
                <div id="toastIconContainer" class="rounded-circle d-flex align-items-center justify-content-center" style="width: 32px; height: 32px;">
                    <i id="toastIcon" class="bi fs-5 text-white"></i>
                </div>
                <div>
                    <strong id="toastTitle" class="d-block text-dark small fw-bold">Success</strong>
                    <span id="toastMessage" class="text-muted small">Action completed.</span>
                </div>
            </div>
            <button type="button" class="btn-close me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
        </div>
    </div>
</div>

<style>
    .bg-success-soft { background: rgba(25, 135, 84, 0.1); }
    .bg-danger-soft { background: rgba(220, 53, 69, 0.1); }
    .bg-warning-soft { background: rgba(255, 193, 7, 0.1); }
    #overlay div { transition: all 0.2s ease-in-out; }
</style>

@section Scripts {
    <script>
        (function () {
            // Read JSON safely from <script type="application/json">
            const boxes = JSON.parse(document.getElementById('boxesJson')?.textContent || '[]');
            const colors = JSON.parse(document.getElementById('colorsJson')?.textContent || '{}');

            const boxCountEl = document.getElementById('boxCount');
            if (boxCountEl) boxCountEl.textContent = boxes.length.toString();

            const img = document.getElementById('mainImg');
            const overlay = document.getElementById('overlay');

            function clearOverlay() {
                if (!overlay) return;
                overlay.innerHTML = '';
            }

            function drawBoxes() {
                if (!img || !overlay) return;

                // ensure overlay matches actual rendered image size
                overlay.style.width = img.clientWidth + 'px';
                overlay.style.height = img.clientHeight + 'px';

                const rect = img.getBoundingClientRect();
                const w = rect.width;
                const h = rect.height;

                clearOverlay();

                boxes.forEach(b => {
                    const div = document.createElement('div');
                    div.style.position = 'absolute';
                    div.style.left = (b.x * w) + 'px';
                    div.style.top = (b.y * h) + 'px';
                    div.style.width = (b.width * w) + 'px';
                    div.style.height = (b.height * h) + 'px';

                    // dictionary keys can be numbers or strings -> normalize
                    const key = (b.labelId != null) ? String(b.labelId) : '';
                    const c = colors[key] || colors[b.labelId] || '#00bcd4';

                    div.style.border = `2px solid ${c}`;
                    div.style.background = c + '22';
                    div.style.borderRadius = '6px';
                    div.style.boxSizing = 'border-box';

                    // Label name tag
                    if (b.labelName) {
                        const tag = document.createElement('span');
                        tag.textContent = b.labelName;
                        tag.style.cssText = `position:absolute;top:-18px;left:0;background:${c};color:#fff;font-size:10px;padding:1px 5px;border-radius:3px;white-space:nowrap;pointer-events:none;`;
                        div.appendChild(tag);
                    }

                    overlay.appendChild(div);
                });
            }

            function onImgReady() {
                drawBoxes();
                window.addEventListener('resize', drawBoxes);
            }

            if (img && img.complete) onImgReady();
            else if (img) img.addEventListener('load', onImgReady);

            // Actions
            const tokenInput = document.querySelector('#antiForgeryForm input[name="__RequestVerificationToken"]');
            const token = tokenInput ? tokenInput.value : null;

            function showActionError(msg) {
                const el = document.getElementById('actionError');
                if (!el) return;
                el.textContent = msg;
                el.classList.remove('d-none');
            }
            function clearActionError() {
                const el = document.getElementById('actionError');
                if (!el) return;
                el.textContent = '';
                el.classList.add('d-none');
            }

            async function postHandler(handler, formData) {
                const res = await fetch(`?handler=${handler}`, {
                    method: 'POST',
                    body: formData,
                    headers: token ? { 'RequestVerificationToken': token } : {}
                });

                const data = await res.json().catch(() => null);
                if (!res.ok || !data || data.ok !== true) {
                    const msg = (data && data.error) ? data.error : `Request failed (${res.status})`;
                    throw new Error(msg);
                }
                return data;
            }

            // Bootstrap modal
            const modalEl = document.getElementById('decisionModal');
            const modal = modalEl ? new bootstrap.Modal(modalEl) : null;
            const titleEl = document.getElementById('decisionTitle');
            const actionEl = document.getElementById('modalAction');
            const commentEl = document.getElementById('modalComment');
            const modalErrorEl = document.getElementById('modalError');
            const confirmBtn = document.getElementById('modalConfirmBtn');

            function showModalError(msg) {
                modalErrorEl.textContent = msg;
                modalErrorEl.classList.remove('d-none');
            }
            function clearModalError() {
                modalErrorEl.textContent = '';
                modalErrorEl.classList.add('d-none');
            }

            const submissionId = @RouteData.Values["submissionId"];

            const btnStart = document.getElementById('btnStartReview');
            if (btnStart) {
                btnStart.addEventListener('click', async () => {
                    try {
                        clearActionError();
                        const fd = new FormData();
                        fd.append('submissionId', submissionId);
                        await postHandler('SetInReview', fd);
                        window.location.reload();
                    } catch (err) {
                        showActionError(err.message || err);
                    }
                });
            }

            const btnApprove = document.getElementById('btnApprove');
            if (btnApprove) {
                btnApprove.addEventListener('click', () => {
                    titleEl.textContent = 'Final Approval';
                    actionEl.value = 'Approve';
                    commentEl.value = '';
                    clearModalError();
                    setupModalUI('Approve');
                    modal.show();
                });
            }

            const btnReject = document.getElementById('btnReject');
            if (btnReject) {
                btnReject.addEventListener('click', () => {
                    titleEl.textContent = 'Rejection Details';
                    actionEl.value = 'Reject';
                    commentEl.value = '';
                    clearModalError();
                    setupModalUI('Reject');
                    modal.show();
                });
            }

            confirmBtn?.addEventListener('click', async () => {
                try {
                    clearModalError();
                    const action = actionEl.value;
                    const comment = commentEl.value || '';

                    const fd = new FormData();
                    fd.append('submissionId', submissionId);
                    fd.append('comment', comment);

                    confirmBtn.disabled = true;
                    confirmBtn.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Processing...';

                    if (action === 'Approve') {
                        const data = await postHandler('Approve', fd);
                        handleNextRedirect(data, 'Approved');
                    }
                    if (action === 'Reject') {
                        const data = await postHandler('Reject', fd);
                        handleNextRedirect(data, 'Rejected');
                    }
                } catch (err) {
                    confirmBtn.disabled = false;
                    confirmBtn.textContent = actionEl.value;
                    showModalError(err.message || err);
                }
            });

            function handleNextRedirect(data, status) {
                modal.hide();
                showToast(status, data.nextSubmissionId ? 'Moving to next image...' : 'All tasks completed.', 'success');
                
                setTimeout(() => {
                    if (data.nextSubmissionId) {
                        window.location.href = `/Reviewer/Review/${data.nextSubmissionId}`;
                    } else {
                        window.location.href = '/Reviewer/Index';
                    }
                }, 600);
            }

            // ========= TOAST HELPER =========
            const toastEl = document.getElementById('feedbackToast');
            const bsToast = new bootstrap.Toast(toastEl, { delay: 3000 });
            
            function showToast(title, message, type = 'success') {
                const titleEl = document.getElementById('toastTitle');
                const messageEl = document.getElementById('toastMessage');
                const iconContainer = document.getElementById('toastIconContainer');
                const icon = document.getElementById('toastIcon');

                titleEl.textContent = title;
                messageEl.textContent = message;
                iconContainer.className = 'rounded-circle d-flex align-items-center justify-content-center';
                icon.className = 'bi fs-5 text-white';

                if (type === 'success') {
                    iconContainer.classList.add('bg-success');
                    icon.classList.add('bi-check-lg');
                    toastEl.style.borderLeft = '5px solid #198754';
                } else if (type === 'danger') {
                    iconContainer.classList.add('bg-danger');
                    icon.classList.add('bi-exclamation-circle');
                    toastEl.style.borderLeft = '5px solid #dc3545';
                }
                bsToast.show();
            }

            function setupModalUI(action) {
                const bg = document.getElementById('modalIconBg');
                const icon = document.getElementById('modalIcon');
                const mainText = document.getElementById('modalMainText');
                const subText = document.getElementById('modalSubText');

                bg.className = 'p-3 rounded-circle me-3';
                icon.className = 'bi fs-3';

                if (action === 'Approve') {
                    bg.classList.add('bg-success-soft');
                    icon.classList.add('bi-check-circle-fill', 'text-success');
                    mainText.textContent = 'Approve Submission?';
                    subText.textContent = 'This will mark the work as verified and final.';
                    confirmBtn.className = 'btn btn-success px-4 fw-bold shadow-sm';
                    confirmBtn.textContent = 'Approve Now';
                } else {
                    bg.classList.add('bg-danger-soft');
                    icon.classList.add('bi-x-circle-fill', 'text-danger');
                    mainText.textContent = 'Reject Submission?';
                    subText.textContent = 'The annotator will need to re-work these boxes.';
                    confirmBtn.className = 'btn btn-danger px-4 fw-bold shadow-sm';
                    confirmBtn.textContent = 'Reject Now';
                }
            }

        })();
    </script>
}