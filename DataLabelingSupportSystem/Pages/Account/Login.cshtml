@page "/"
@model LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
    var returnUrl = (string?)Request.Query["ReturnUrl"];
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DataLabelingSupportSystem</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" />

    <style>
        .auth-bg {
            min-height: 100vh;
            background: linear-gradient(135deg, #e8f3ff 0%, #f7fbff 45%, #ffffff 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 32px 12px;
        }

        .auth-card {
            border: 0;
            border-radius: 24px;
            box-shadow: 0 20px 60px rgba(16, 93, 181, .15);
            overflow: hidden;
            width: 880px;
            max-width: 100%;
            animation: popIn .4s ease-out;
        }

        .auth-left {
            background: linear-gradient(135deg, #0d6efd 0%, #47b2ff 100%);
            color: #fff;
            padding: 40px;
            height: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .auth-badge {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 999px;
            background: rgba(255,255,255,.15);
            border: 1px solid rgba(255,255,255,.2);
            font-size: 13px;
            font-weight: 500;
            letter-spacing: .3px;
            backdrop-filter: blur(4px);
        }

        .auth-title {
            font-weight: 850;
            margin-top: 20px;
            margin-bottom: 10px;
            line-height: 1.1;
            font-size: 2.2rem;
        }

        .auth-subtitle {
            opacity: .85;
            margin: 0;
            font-size: 1.1rem;
        }

        .auth-illustration {
            width: 100%;
            height: auto;
            margin-top: 40px;
            filter: drop-shadow(0 25px 40px rgba(0, 0, 0, 0.2));
            animation: float 6s ease-in-out infinite;
        }

        .auth-right {
            padding: 40px;
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .form-control.auth-input {
            border-radius: 12px;
            padding: 12px 14px;
            border: 1px solid #dbe7f6;
            transition: .2s ease;
        }

            .form-control.auth-input:focus {
                border-color: #7db8ff;
                box-shadow: 0 0 0 .25rem rgba(13,110,253,.15);
            }

        .btn-auth {
            border-radius: 12px;
            padding: 10px 14px;
            background: linear-gradient(135deg, #0d6efd 0%, #47b2ff 100%);
            border: 0;
            box-shadow: 0 10px 20px rgba(13,110,253,.18);
        }

        .btn-outline-soft {
            border-radius: 12px;
            padding: 10px 14px;
            border: 1px solid #bcd8ff;
            color: #0d6efd;
            background: rgba(13,110,253,.06);
            text-decoration: none;
        }

            .btn-outline-soft:hover {
                background: rgba(13,110,253,.10);
                color: #0b5ed7;
            }

        .auth-divider {
            display: flex;
            align-items: center;
            text-align: center;
            margin: 24px 0;
            color: #b0c4de;
            font-size: 13px;
        }

            .auth-divider::before,
            .auth-divider::after {
                content: '';
                flex: 1;
                border-bottom: 1px solid #e1eaf5;
            }

            .auth-divider:not(:empty)::before {
                margin-right: 12px;
            }

            .auth-divider:not(:empty)::after {
                margin-left: 12px;
            }

        .btn-social {
            border-radius: 12px;
            padding: 10px 14px;
            border: 1px solid #e1eaf5;
            background: #fff;
            color: #4a5568;
            font-size: 14px;
            font-weight: 500;
            transition: all .2s;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            width: 100%;
        }

            .btn-social:hover {
                background: #f8faff;
                border-color: #d1e2f7;
                color: #2d3748;
                transform: translateY(-1px);
            }

        .forgot-link {
            font-size: 13px;
            color: #6b8db3;
            text-decoration: none;
            transition: .2s;
        }

            .forgot-link:hover {
                color: #0d6efd;
            }

        @@keyframes float {
            0%, 100% {
                transform: translateY(0);
            }

            50% {
                transform: translateY(-20px);
            }
        }

        @@keyframes popIn {
            from {
                transform: translateY(6px);
                opacity: 0;
            }

            to {
                transform: translateY(0);
                opacity: 1;
            }
        }
    </style>
</head>

<body>
    <div class="auth-bg">
        <div class="card auth-card">
            <div class="row g-0">
                <div class="col-lg-6">
                    <div class="auth-left">
                        <div class="text-center text-lg-start">
                            <span class="auth-badge">Data Labeling Support System</span>
                            <h2 class="auth-title">Welcome back</h2>
                            <p class="auth-subtitle">Sign in to continue.</p>
                        </div>
                        <div class="text-center mt-5">
                            <img src="~/images/login-illustration.png" alt="Illustration" class="auth-illustration" />
                        </div>
                    </div>
                </div>

                <div class="col-lg-6">
                    <div class="auth-right">
                        <h3 class="mt-4 mb-3" style="font-weight:800; color:#0b3b6d;">Login</h3>

                        @if (!string.IsNullOrEmpty(Model.Error))
                        {
                            <div class="alert alert-danger py-2 mb-3" role="alert">
                                @Model.Error
                            </div>
                        }

                        <form method="post">
                            <div class="mb-3">
                                <label class="form-label">Username</label>
                                <input class="form-control auth-input" asp-for="Input.Username" autocomplete="username" />
                                <span asp-validation-for="Input.Username" class="text-danger"></span>
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Password</label>
                                <input class="form-control auth-input" asp-for="Input.Password" type="password" autocomplete="current-password" />
                                <span asp-validation-for="Input.Password" class="text-danger"></span>
                            </div>

                             <div class="d-flex align-items-center justify-content-between mb-3">
                                <div class="form-check">
                                    <input class="form-check-input" asp-for="Input.RememberMe" />
                                    <label class="form-check-label" asp-for="Input.RememberMe">Remember me</label>
                                </div>

                                <a href="#" class="forgot-link">Forgot password?</a>
                            </div>

                            <button type="submit" class="btn btn-auth text-white w-100 mb-3">
                                Login
                            </button>

                            <div class="auth-divider">Or continue with</div>

                            <div class="row g-2">
                                <div class="col-6">
                                    <button type="button" class="btn btn-social">
                                        <i class="fa-brands fa-google text-danger"></i> Google
                                    </button>
                                </div>
                                <div class="col-6">
                                    <button type="button" class="btn btn-social">
                                        <i class="fa-brands fa-github text-dark"></i> GitHub
                                    </button>
                                </div>
                            </div>
                        </form>

                        <div class="text-center mt-4">
                            <span style="color:#6b8db3; font-size: 14px;">Don't have an account?</span>
                            <a class="ms-1" style="font-weight:600; text-decoration:none; color:#0d6efd;"
                               asp-page="/Account/Register"
                               asp-route-returnUrl="@returnUrl">
                                Create account
                            </a>
                        </div>

                        <div class="text-center mt-3" style="color:#6b8db3; font-size: 13px;">
                            © 2026 DataLabelingSupportSystem
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
